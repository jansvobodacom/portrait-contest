<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= settings.contest_title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Inter:wght@400;500&display=swap" rel="stylesheet">
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    :root{--bg:<%= settings.color_bg||'#fafaf8' %>;--surface:#fff;--text:<%= settings.color_primary||'#1a1a18' %>;--text2:#5a5955;--text3:#9a9893;--border:rgba(0,0,0,0.09);--r:6px}
    body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh}
    a{color:inherit;text-decoration:none}
    nav{background:var(--surface);border-bottom:0.5px solid var(--border);position:sticky;top:0;z-index:100}
    .nav-inner{max-width:720px;margin:0 auto;padding:0 2rem;height:56px;display:flex;align-items:center;justify-content:space-between}
    .nav-logo{font-family:'Playfair Display',serif;font-size:16px}
    .nav-logo em{font-style:italic;color:var(--text2)}
    .nav-links{display:flex;gap:1.5rem}
    .nav-links a{font-size:12px;color:var(--text2);letter-spacing:.5px;text-transform:uppercase}
    .nav-links a:hover{color:var(--text)}
    .center{max-width:480px;margin:8rem auto;padding:0 2rem;text-align:center}
    .icon{font-size:40px;margin-bottom:1.5rem;opacity:.3}
    h1{font-family:'Playfair Display',serif;font-size:26px;font-weight:400;margin-bottom:.75rem}
    p{font-size:15px;color:var(--text2);line-height:1.7;margin-bottom:2rem}
    .btn{display:inline-block;background:var(--text);color:var(--bg);padding:10px 22px;border-radius:var(--r);font-size:13px;font-weight:500}
    footer{text-align:center;padding:2rem;font-size:12px;color:var(--text3);border-top:0.5px solid var(--border);position:fixed;bottom:0;width:100%;background:var(--bg)}
  </style>
</head>
<body>
<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo"><%- settings.footer_text||'Jan Svoboda Photography' %> </a>
    <div class="nav-links">
      <a href="/">Domů</a>
      <a href="/pravidla">Pravidla</a>
      <% if(typeof isAdmin!=='undefined'&&isAdmin){%><a href="/admin">Admin</a><%}%>
    </div>
  </div>
</nav>
<div class="center">
  <div class="icon">🔒</div>
  <h1><%= settings.contest_title %></h1>
  <p><%= message %></p>
  <a href="/" class="btn">Zpět na hlavní stránku</a>
</div>
</body>
</html>
