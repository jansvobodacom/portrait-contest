<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Výsledky – <%= settings.contest_title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{--bg:<%= settings.color_bg||'#fafaf8' %>;--surface:#fff;--text:<%= settings.color_primary||'#1a1a18' %>;--text2:#5a5955;--text3:#9a9893;--border:rgba(0,0,0,0.09);--accent:<%= settings.color_accent||'#0F6E56' %>;--accent-bg:#E1F5EE;--amber:#854F0B;--amber-bg:#FAEEDA;--amber-brd:#FAC775;--r:6px}
    body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh}
    a{color:inherit;text-decoration:none}
    nav{background:var(--surface);border-bottom:0.5px solid var(--border);position:sticky;top:0;z-index:100}
    .nav-inner{max-width:720px;margin:0 auto;padding:0 2rem;height:56px;display:flex;align-items:center;justify-content:space-between}
    .nav-logo{font-family:'Playfair Display',serif;font-size:16px}
    .nav-logo em{font-style:italic;color:var(--text2)}
    .nav-links{display:flex;gap:1.5rem}
    .nav-links a{font-size:12px;color:var(--text2);letter-spacing:.5px;text-transform:uppercase;transition:color .2s}
    .nav-links a:hover,.nav-links a.active{color:var(--text)}
    .hamburger{display:none;flex-direction:column;gap:4px;cursor:pointer;padding:4px}
    .hamburger span{width:20px;height:1.5px;background:var(--text);display:block}
    .mobile-menu{display:none;position:fixed;inset:0;background:var(--surface);z-index:99;padding:5rem 2rem 2rem;flex-direction:column;gap:1.5rem}
    .mobile-menu.open{display:flex}
    .mobile-menu a{font-size:22px;font-family:"Playfair Display",serif;color:var(--text)}
    .mobile-close{position:absolute;top:1.25rem;right:2rem;font-size:24px;cursor:pointer;color:var(--text2)}
    @media(max-width:600px){.nav-links{display:none}.hamburger{display:flex}}
    .wrap{max-width:720px;margin:0 auto;padding:0 2rem}
    .page-header{padding:2rem 0 1.5rem}
    .page-title{font-family:'Playfair Display',serif;font-size:30px;font-weight:400;letter-spacing:-.8px;margin-bottom:4px}
    .page-sub{font-size:13px;color:var(--text2)}
    .voting-note{background:var(--accent-bg);border:0.5px solid #5DCAA5;border-radius:var(--r);padding:10px 14px;font-size:13px;color:var(--accent);margin-bottom:1.5rem}
    .winner-box{background:var(--amber-bg);border:0.5px solid var(--amber-brd);border-radius:var(--r);padding:1.5rem;display:flex;align-items:center;gap:1.25rem;margin-bottom:2rem}
    .winner-img{width:72px;height:72px;object-fit:cover;border-radius:var(--r);flex-shrink:0}
    .winner-label{font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--amber);margin-bottom:5px}
    .winner-name{font-family:'Playfair Display',serif;font-size:20px;font-weight:400;color:#633806;margin-bottom:3px}
    .winner-votes{font-size:13px;color:var(--amber)}
    .result-row{display:flex;align-items:center;gap:1rem;padding:1rem 0;border-bottom:0.5px solid var(--border)}
    .result-row:last-child{border-bottom:none}
    .rank{font-family:'Playfair Display',serif;font-size:20px;width:32px;flex-shrink:0;color:var(--text3);font-weight:400}
    .rank.top{color:var(--text)}
    .result-img{width:48px;height:48px;object-fit:cover;border-radius:var(--r);flex-shrink:0}
    .result-info{flex:1;min-width:0}
    .result-num{font-size:11px;color:var(--text3);letter-spacing:.5px;text-transform:uppercase;margin-bottom:5px}
    .bar-wrap{height:3px;background:var(--border);border-radius:2px}
    .bar{height:3px;border-radius:2px;background:var(--text)}
    .result-votes{font-size:14px;font-weight:500;flex-shrink:0;text-align:right;min-width:55px}
    .result-votes span{font-size:11px;font-weight:400;color:var(--text3);margin-left:2px}
    .empty{text-align:center;padding:5rem;color:var(--text2)}
    footer{background:var(--surface);border-top:0.5px solid var(--border);margin-top:3rem}
    .footer-inner{max-width:720px;margin:0 auto;padding:1.5rem 2rem;display:flex;align-items:center;justify-content:space-between}
    .footer-logo{font-family:'Playfair Display',serif;font-size:14px}
    .footer-links{display:flex;gap:1.5rem}
    .footer-links a{font-size:12px;color:var(--text2)}
  </style>
</head>
<body>
<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">Jan Svoboda <em>Photography</em></a>
    <div class="nav-links">
      <a href="/">Domů</a>
      <a href="/galerie">Galerie</a>
      <a href="/vysledky" class="active">Výsledky</a>
      <a href="/pravidla">Pravidla</a>
      <% if(typeof isAdmin!=='undefined'&&isAdmin){%><a href="/admin">Admin</a><%}%>
    </div>
    <div class="hamburger" onclick="document.getElementById('mm-results').classList.add('open');document.body.style.overflow='hidden'"><span></span><span></span><span></span></div>
  </div>
</nav>
<div class="wrap">
  <div class="page-header">
    <h1 class="page-title"><%= settings.phase==='results'?'Výsledky':'Průběžné výsledky' %></h1>
    <p class="page-sub"><%= settings.phase==='voting'?'Hlasování stále probíhá.':settings.phase==='results'?'Hlasování ukončeno.':'Přehled přihlášených.' %></p>
  </div>

  <% if(settings.phase==='voting'){%>
    <div class="voting-note">Ještě jste nehlasoval/a? <a href="/galerie" style="font-weight:500;text-decoration:underline;color:var(--accent)">Přejít do galerie →</a></div>
  <%}%>

  <% if(settings.phase==='results'&&entries.length>0&&entries[0].votes>0){%>
  <div class="winner-box">
    <img src="/uploads/<%= entries[0].photo %>" class="winner-img" alt="">
    <div>
      <div class="winner-label">🏆 Vítěz</div>
      <div class="winner-name">Účastník č. <%= entries[0].anon_number %></div>
      <div class="winner-votes"><%= settings.prize_description %></div>
    </div>
  </div>
  <%}%>

  <%if(entries.length===0){%>
    <div class="empty">Zatím žádné výsledky.</div>
  <%}else{%>
    <% const maxV=Math.max(entries[0].votes,1); %>
    <%entries.forEach((e,i)=>{%>
    <div class="result-row">
      <span class="rank <%=i<3?'top':''%>"><%=i+1%></span>
      <img src="/uploads/<%= e.photo %>" class="result-img" alt="">
      <div class="result-info">
        <div class="result-num">Účastník č. <%= e.anon_number %></div>
        <div class="bar-wrap"><div class="bar" style="width:<%=Math.round(e.votes/maxV*100)%>%"></div></div>
      </div>
      <div class="result-votes" style="display:none"><%= e.votes %><span>hl.</span></div>
    </div>
    <%})%>
  <%}%>
</div>
<footer>
  <div class="footer-inner">
    <div class="footer-logo">Jan Svoboda Photography</div>
    <div class="footer-links"><a href="/pravidla">Pravidla</a><a href="/admin/login">Admin</a></div>
  </div>
</footer>
</body>
</html>
