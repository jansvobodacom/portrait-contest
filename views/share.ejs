<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Zadeček č. <%= entry.anon_number %> – <%= settings.contest_title %></title>
  <meta property="og:title" content="Zadeček č. <%= entry.anon_number %> – <%= settings.contest_title %>">
  <meta property="og:description" content="Hlasujte pro Zadečka č. <%= entry.anon_number %>! Klikněte a odevzdejte svůj hlas.">
  <meta property="og:image" content="<%= appUrl %>/uploads/<%= entry.photo %>">
  <meta property="og:url" content="<%= appUrl %>/zadecek/<%= entry.id %>">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:image" content="<%= appUrl %>/uploads/<%= entry.photo %>">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&family=Inter:wght@400;500&display=swap" rel="stylesheet">
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    :root{--bg:#fafaf8;--surface:#fff;--text:#1a1a18;--text2:#5a5955;--text3:#9a9893;--border:rgba(0,0,0,0.09);--border2:rgba(0,0,0,0.18);--accent:#0F6E56;--accent-bg:#E1F5EE;--accent-brd:#5DCAA5;--amber:#854F0B;--amber-bg:#FAEEDA;--amber-brd:#FAC775;--red:#A32D2D;--red-bg:#FCEBEB;--r:6px}
    body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:2rem}
    .card{background:var(--surface);border:0.5px solid var(--border);border-radius:10px;overflow:hidden;max-width:440px;width:100%;margin-top:2rem}
    .photo{width:100%;aspect-ratio:3/4;object-fit:cover;display:block}
    .info{padding:1.5rem}
    .label{font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:var(--text2);margin-bottom:8px}
    .num{font-family:'Playfair Display',serif;font-size:28px;font-weight:400;margin-bottom:1.25rem}
    .vote-box{background:var(--bg);border:0.5px solid var(--border);border-radius:var(--r);padding:1rem;margin-bottom:1rem}
    .vote-label{font-size:11px;color:var(--text2);letter-spacing:.5px;text-transform:uppercase;margin-bottom:10px}
    input[type=email]{width:100%;padding:10px 14px;font-size:14px;border:0.5px solid var(--border2);border-radius:var(--r);background:var(--surface);color:var(--text);font-family:'Inter',sans-serif;margin-bottom:8px}
    input:focus{outline:none;border-color:var(--text)}
    .btn-vote{width:100%;padding:11px;background:var(--text);color:var(--bg);border:none;border-radius:var(--r);font-size:13px;font-weight:500;cursor:pointer;font-family:'Inter',sans-serif}
    .btn-vote:hover{opacity:.85}
    .btn-vote:disabled{opacity:.5;cursor:wait}
    .btn-vote.voted{background:var(--accent)}
    .msg{font-size:13px;margin-top:8px;display:none}
    .msg.success{color:var(--accent)}
    .msg.error{color:var(--red)}
    .switch-box{background:var(--amber-bg);border:0.5px solid var(--amber-brd);border-radius:var(--r);padding:1rem;margin-top:10px;display:none}
    .switch-text{font-size:13px;color:var(--amber);line-height:1.5;margin-bottom:10px}
    .switch-btns{display:flex;gap:8px}
    .btn-yes{flex:1;padding:9px;background:var(--text);color:var(--bg);border:none;border-radius:var(--r);font-size:13px;font-weight:500;cursor:pointer;font-family:'Inter',sans-serif}
    .btn-no{flex:1;padding:9px;background:transparent;color:var(--text2);border:0.5px solid var(--border2);border-radius:var(--r);font-size:13px;cursor:pointer;font-family:'Inter',sans-serif}
    .back{font-size:13px;color:var(--text2);margin-top:1rem;text-align:center}
    .back a{color:var(--text);text-decoration:underline}
    .toast{position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(20px);background:var(--text);color:var(--bg);padding:10px 22px;border-radius:50px;font-size:13px;font-weight:500;opacity:0;transition:all .3s;pointer-events:none;z-index:400;white-space:nowrap}
    .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
  </style>
</head>
<body>
  <div class="card">
    <img src="/uploads/<%= entry.photo %>" class="photo" alt="Zadeček č. <%= entry.anon_number %>">
    <div class="info">
      <div class="label"><%= settings.contest_title %></div>
      <div class="num">Zadeček č. <%= entry.anon_number %></div>

      <% if(settings.phase==='voting'){ %>
      <div class="vote-box">
        <div class="vote-label">Hlasovat</div>
        <input type="email" id="email" placeholder="vas@email.cz">
        <button id="vote-btn" class="btn-vote" onclick="doVote()">♡ Hlasovat pro tohoto zadečka</button>
        <div id="err-msg" class="msg error"></div>
        <div id="suc-msg" class="msg success">✓ Hlas byl zaznamenán!</div>
        <div id="switch-box" class="switch-box">
          <div id="switch-text" class="switch-text"></div>
          <div class="switch-btns">
            <button class="btn-yes" onclick="doSwitch()">Ano, změnit hlas</button>
            <button class="btn-no" onclick="hideSwitch()">Ne, ponechat</button>
          </div>
        </div>
      </div>
      <% }else if(settings.phase==='registration'){ %>
      <div style="font-size:13px;color:var(--text2);margin-bottom:1rem;padding:1rem;background:var(--bg);border-radius:var(--r);border:0.5px solid var(--border)">
        Hlasování ještě nezačalo. Sledujte nás!
      </div>
      <% }else{ %>
      <div style="font-size:13px;color:var(--text2);margin-bottom:1rem;padding:1rem;background:var(--bg);border-radius:var(--r);border:0.5px solid var(--border)">
        Hlasování již skončilo. <a href="/vysledky" style="color:var(--text);text-decoration:underline">Výsledky →</a>
      </div>
      <% } %>

      <a href="/" style="display:block;text-align:center;font-size:13px;color:var(--text2)">← Zpět na hlavní stránku</a>
    </div>
  </div>
  <div class="toast" id="toast"></div>

<% if(settings.phase==='voting'){ %>
<script>
const ENTRY_ID = <%= entry.id %>;
const ANON = <%= entry.anon_number %>;
let pendingSwitch = null;

function hideSwitch(){document.getElementById('switch-box').style.display='none';pendingSwitch=null;}

async function doVote(){
  const email = document.getElementById('email').value.trim();
  const errEl = document.getElementById('err-msg');
  const sucEl = document.getElementById('suc-msg');
  const btn = document.getElementById('vote-btn');
  const sw = document.getElementById('switch-box');
  const swText = document.getElementById('switch-text');

  if(!email||!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)){errEl.textContent='Zadejte platný e-mail.';errEl.style.display='block';return;}
  btn.disabled=true;btn.textContent='Odesílám...';
  errEl.style.display='none';sw.style.display='none';

  try{
    const r=await fetch('/hlasovat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({entry_id:ENTRY_ID,voter_email:email})});
    const data=await r.json();
    if(!data.ok){
      btn.disabled=false;
      if(data.canSwitch){
        btn.textContent='♡ Hlasovat pro tohoto zadečka';
        swText.textContent=data.error;
        sw.style.display='block';
        pendingSwitch={email,newId:ENTRY_ID,oldId:data.oldEntryId};
      }else{
        errEl.textContent=data.error;errEl.style.display='block';
        btn.textContent='♡ Hlasovat pro tohoto zadečka';
      }
      return;
    }
    btn.disabled=false;btn.textContent='♥ Hlasováno!';btn.className='btn-vote voted';
    sucEl.style.display='block';
    showToast('✓ Hlas zaznamenán!');
  }catch{errEl.textContent='Chyba připojení.';errEl.style.display='block';btn.disabled=false;btn.textContent='♡ Hlasovat pro tohoto zadečka';}
}

async function doSwitch(){
  if(!pendingSwitch)return;
  const {email,newId}=pendingSwitch;
  hideSwitch();
  const btn=document.getElementById('vote-btn');
  const errEl=document.getElementById('err-msg');
  const sucEl=document.getElementById('suc-msg');
  btn.disabled=true;btn.textContent='Odesílám...';
  try{
    const r=await fetch('/hlasovat-prepsat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({entry_id:newId,voter_email:email})});
    const data=await r.json();
    if(!data.ok){errEl.textContent=data.error;errEl.style.display='block';btn.disabled=false;btn.textContent='♡ Hlasovat pro tohoto zadečka';return;}
    btn.disabled=false;btn.textContent='♥ Hlasováno!';btn.className='btn-vote voted';
    sucEl.style.display='block';
    showToast('✓ Hlas byl změněn!');
  }catch{errEl.textContent='Chyba.';errEl.style.display='block';btn.disabled=false;btn.textContent='♡ Hlasovat pro tohoto zadečka';}
}

function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),3000);}
</script>
<% } %>
</body>
</html>
