<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Galerie – <%= settings.contest_title %></title>
  <style>
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
    :root { --bg:#fafaf9; --bg2:#f1f0ec; --surface:#fff; --text:#1a1a18; --text2:#5a5955; --text3:#9a9893; --border:rgba(0,0,0,0.1); --border2:rgba(0,0,0,0.2); --green:#0F6E56; --green-bg:#E1F5EE; --green-brd:#5DCAA5; --red:#A32D2D; --red-bg:#FCEBEB; --r:10px; }
    body { font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; background:var(--bg); color:var(--text); }
    a { color:inherit; text-decoration:none; }
    nav { background:var(--surface); border-bottom:0.5px solid var(--border); position:sticky; top:0; z-index:50; }
    .nav-inner { max-width:960px; margin:0 auto; padding:0 1.5rem; height:54px; display:flex; align-items:center; justify-content:space-between; }
    .nav-logo { font-size:15px; font-weight:500; }
    .nav-links { display:flex; gap:2px; }
    .nav-links a { padding:6px 13px; border-radius:7px; font-size:13px; color:var(--text2); transition:all .15s; }
    .nav-links a:hover, .nav-links a.active { background:var(--bg2); color:var(--text); }
    .container { max-width:960px; margin:0 auto; padding:2rem 1.5rem; }
    footer { text-align:center; padding:2rem; font-size:13px; color:var(--text3); border-top:0.5px solid var(--border); margin-top:3rem; }
    h1 { font-size:22px; font-weight:500; letter-spacing:-.4px; margin-bottom:6px; }
    .subtitle { font-size:14px; color:var(--text2); margin-bottom:1.5rem; }
    /* Phase banners */
    .phase-note { padding:12px 16px; border-radius:7px; font-size:14px; margin-bottom:1.5rem; display:flex; align-items:center; gap:10px; }
    .pn-gray { background:var(--bg2); color:var(--text2); }
    .pn-green { background:var(--green-bg); color:var(--green); border:0.5px solid var(--green-brd); }
    /* Voter info bar */
    .voter-bar { background:var(--green-bg); border:0.5px solid var(--green-brd); border-radius:7px; padding:10px 16px; font-size:13px; color:var(--green); margin-bottom:1.5rem; display:flex; align-items:center; gap:8px; }
    /* Grid */
    .grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:16px; }
    .card { background:var(--surface); border:0.5px solid var(--border); border-radius:var(--r); overflow:hidden; transition:transform .15s; }
    .card:hover { transform:translateY(-2px); }
    .thumb { height:210px; overflow:hidden; position:relative; background:var(--bg2); }
    .thumb img { width:100%; height:100%; object-fit:cover; }
    .voted-tag { position:absolute; top:8px; right:8px; background:rgba(15,110,86,.88); color:#fff; font-size:10px; font-weight:600; padding:3px 9px; border-radius:20px; }
    .info { padding:12px 14px; }
    .name { font-size:14px; font-weight:500; margin-bottom:3px; }
    .note { font-size:12px; color:var(--text2); margin-bottom:10px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; min-height:18px; }
    .vote-row { display:flex; align-items:center; justify-content:space-between; }
    .vote-count { font-size:13px; color:var(--text2); }
    .vote-count b { color:var(--text); }
    .btn-vote { display:flex; align-items:center; gap:5px; padding:6px 14px; font-size:13px; border-radius:7px; cursor:pointer; border:0.5px solid var(--border2); background:transparent; color:var(--text); transition:all .15s; font-family:inherit; }
    .btn-vote:hover { background:var(--bg2); }
    .btn-vote.voted { background:var(--red-bg); border-color:#F09595; color:var(--red); }
    .btn-vote:disabled { opacity:.4; cursor:not-allowed; }
    /* Modal */
    .modal-wrap { display:none; position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:200; align-items:center; justify-content:center; padding:1rem; }
    .modal-wrap.open { display:flex; }
    .modal { background:var(--surface); border-radius:var(--r); padding:1.75rem; width:100%; max-width:380px; box-shadow:0 8px 32px rgba(0,0,0,.12); }
    .modal h3 { font-size:17px; font-weight:500; margin-bottom:6px; }
    .modal p { font-size:14px; color:var(--text2); margin-bottom:16px; line-height:1.5; }
    .modal-photo { display:flex; align-items:center; gap:12px; background:var(--bg2); border-radius:7px; padding:10px 12px; margin-bottom:16px; }
    .modal-photo img { width:48px; height:48px; object-fit:cover; border-radius:6px; }
    .modal-photo span { font-size:14px; font-weight:500; }
    .modal label { font-size:12px; color:var(--text2); font-weight:500; display:block; margin-bottom:6px; }
    .modal input { width:100%; padding:9px 12px; font-size:14px; border:0.5px solid var(--border2); border-radius:7px; background:var(--bg); color:var(--text); font-family:inherit; margin-bottom:4px; }
    .modal input:focus { outline:none; border-color:var(--text); }
    .modal-hint { font-size:12px; color:var(--text3); margin-bottom:16px; }
    .modal-err { font-size:13px; color:var(--red); margin-bottom:12px; display:none; }
    .modal-actions { display:flex; gap:8px; }
    .btn-submit { flex:1; padding:10px; background:var(--text); color:var(--bg); border:none; border-radius:7px; font-size:14px; font-weight:500; cursor:pointer; font-family:inherit; transition:opacity .15s; }
    .btn-submit:hover { opacity:.85; }
    .btn-submit:disabled { opacity:.5; cursor:wait; }
    .btn-cancel { padding:10px 18px; background:transparent; border:0.5px solid var(--border2); border-radius:7px; font-size:14px; cursor:pointer; font-family:inherit; }
    .empty { text-align:center; padding:4rem; color:var(--text2); }
  </style>
</head>
<body>
<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">📸 <%= settings.contest_title %></a>
    <div class="nav-links">
      <a href="/">Domů</a>
      <a href="/galerie" class="active">Galerie</a>
      <a href="/vysledky">Výsledky</a>
      <a href="/pravidla">Pravidla</a>
      <% if (typeof isAdmin !== 'undefined' && isAdmin) { %><a href="/admin">Admin</a><% } %>
    </div>
  </div>
</nav>
<div class="container">
  <h1>Galerie fotografií</h1>

  <% if (settings.phase === 'registration') { %>
    <div class="phase-note pn-gray">📋 Přihlašování stále probíhá. Hlasování bude spuštěno brzy.</div>
  <% } else if (settings.phase === 'voting') { %>
    <% if (voterEmail) { %>
      <div class="voter-bar">✓ Hlasujete jako <strong><%= voterEmail %></strong><% if (votedFor) { %> &nbsp;·&nbsp; váš hlas je odevzdán<% } %></div>
    <% } else { %>
      <div class="phase-note pn-green">🗳 Hlasování je otevřeno! Klikněte na srdce u fotografie a zadejte svůj e-mail.</div>
    <% } %>
  <% } else { %>
    <div class="phase-note pn-gray">🏁 Hlasování je ukončeno. <a href="/vysledky" style="color:var(--text);font-weight:500;text-decoration:underline;">Zobrazit výsledky →</a></div>
  <% } %>

  <p class="subtitle" style="margin-top:0;"><%= entries.length %> fotografií v galerii</p>

  <% if (entries.length === 0) { %>
    <div class="empty">Zatím žádné schválené fotografie.</div>
  <% } else { %>
  <div class="grid" id="gallery-grid">
    <% entries.forEach(e => { const isVoted = votedFor === e.id; %>
    <div class="card" id="card-<%= e.id %>">
      <div class="thumb">
        <img src="/uploads/<%= e.photo %>" alt="<%= e.name %>" loading="lazy">
        <% if (isVoted) { %><span class="voted-tag">✓ Váš hlas</span><% } %>
      </div>
      <div class="info">
        <div class="name"><%= e.name %></div>
        <div class="note"><%= e.note || '' %></div>
        <div class="vote-row">
          <span class="vote-count" id="vc-<%= e.id %>"><b><%= e.votes %></b> hlasů</span>
          <% if (settings.phase === 'voting') { %>
            <button class="btn-vote <%= isVoted?'voted':'' %>" id="vbtn-<%= e.id %>"
              onclick="openModal(<%= e.id %>, '<%= e.name.replace(/'/g,"\\'") %>', '/uploads/<%= e.photo %>')">
              <span><%= isVoted?'♥':'♡' %></span>
              <span><%= isVoted?'Hlasováno':'Hlasovat' %></span>
            </button>
          <% } %>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>

<!-- Modal pro hlasování -->
<div class="modal-wrap" id="modal-wrap" onclick="closeOnBg(event)">
  <div class="modal">
    <h3>Potvrdit hlas</h3>
    <p>Hlasujete pro:</p>
    <div class="modal-photo">
      <img id="modal-img" src="" alt="">
      <span id="modal-name"></span>
    </div>
    <label>Váš e-mail *</label>
    <input type="email" id="modal-email" placeholder="vas@email.cz" value="<%= voterEmail || '' %>">
    <div class="modal-hint">Každý e-mail může hlasovat jednou. Váš e-mail nebude zveřejněn.</div>
    <div class="modal-err" id="modal-err"></div>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeModal()">Zrušit</button>
      <button class="btn-submit" id="modal-submit" onclick="submitVote()">Hlasovat ♥</button>
    </div>
  </div>
</div>

<footer>© 2026 Jan Svoboda Photography</footer>
<script>
  let pendingId = null;
  const currentVotedFor = <%= JSON.stringify(votedFor) %>;

  function openModal(id, name, photo) {
    pendingId = id;
    document.getElementById('modal-name').textContent = name;
    document.getElementById('modal-img').src = photo;
    document.getElementById('modal-err').style.display = 'none';
    document.getElementById('modal-wrap').classList.add('open');
    setTimeout(() => document.getElementById('modal-email').focus(), 50);
  }
  function closeModal() { document.getElementById('modal-wrap').classList.remove('open'); pendingId = null; }
  function closeOnBg(e) { if (e.target === document.getElementById('modal-wrap')) closeModal(); }
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
  document.getElementById('modal-email').addEventListener('keydown', e => { if (e.key === 'Enter') submitVote(); });

  async function submitVote() {
    const email = document.getElementById('modal-email').value.trim();
    const errEl = document.getElementById('modal-err');
    const btn = document.getElementById('modal-submit');
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      errEl.textContent = 'Zadejte platný e-mail.'; errEl.style.display = 'block'; return;
    }
    btn.disabled = true; btn.textContent = 'Odesílám...';
    try {
      const r = await fetch('/hlasovat', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ entry_id: pendingId, voter_email: email }) });
      const data = await r.json();
      if (!data.ok) { errEl.textContent = data.error; errEl.style.display = 'block'; btn.disabled = false; btn.textContent = 'Hlasovat ♥'; return; }

      // Aktualizuj UI – odeber starý hlas pokud přehlasování
      if (data.oldEntryId) {
        const prevBtn = document.getElementById('vbtn-' + data.oldEntryId);
        if (prevBtn) { prevBtn.className = 'btn-vote'; prevBtn.innerHTML = '<span>♡</span><span>Hlasovat</span>'; }
        const prevThumb = document.querySelector('#card-' + data.oldEntryId + ' .voted-tag');
        if (prevThumb) prevThumb.remove();
      }
      // Nastav nový hlas
      const newBtn = document.getElementById('vbtn-' + pendingId);
      const vc = document.getElementById('vc-' + pendingId);
      if (newBtn) { newBtn.className = 'btn-vote voted'; newBtn.innerHTML = '<span>♥</span><span>Hlasováno</span>'; }
      if (vc) vc.innerHTML = '<b>' + data.votes + '</b> hlasů';
      const thumb = document.querySelector('#card-' + pendingId + ' .thumb');
      if (thumb && !thumb.querySelector('.voted-tag')) {
        const t = document.createElement('span'); t.className='voted-tag'; t.textContent='✓ Váš hlas'; thumb.appendChild(t);
      }
      closeModal();
      // Aktualizuj voter bar
      const vBar = document.querySelector('.voter-bar');
      if (!vBar) {
        const note = document.querySelector('.phase-note.pn-green');
        if (note) { note.className = 'voter-bar'; note.innerHTML = '✓ Hlasujete jako <strong>' + email + '</strong> · váš hlas je odevzdán'; }
      }
    } catch { errEl.textContent = 'Chyba připojení.'; errEl.style.display='block'; btn.disabled=false; btn.textContent='Hlasovat ♥'; }
  }
</script>
</body>
</html>
