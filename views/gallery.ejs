<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Galerie – <%= settings.contest_title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{--bg:<%= settings.color_bg||'#fafaf8' %>;--surface:#fff;--text:<%= settings.color_primary||'#1a1a18' %>;--text2:#5a5955;--text3:#9a9893;--border:rgba(0,0,0,0.09);--border2:rgba(0,0,0,0.18);--accent:<%= settings.color_accent||'#0F6E56' %>;--accent-bg:#E1F5EE;--accent-brd:#5DCAA5;--red:#A32D2D;--red-bg:#FCEBEB;--r:6px}
    body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh}
    a{color:inherit;text-decoration:none}
    nav{background:var(--surface);border-bottom:0.5px solid var(--border);position:sticky;top:0;z-index:100}
    .nav-inner{max-width:960px;margin:0 auto;padding:0 2rem;height:56px;display:flex;align-items:center;justify-content:space-between}
    .nav-logo{font-family:'Playfair Display',serif;font-size:16px}
    .nav-logo em{font-style:italic;color:var(--text2)}
    .nav-links{display:flex;gap:1.5rem}
    .nav-links a{font-size:12px;color:var(--text2);letter-spacing:.5px;text-transform:uppercase;transition:color .2s}
    .nav-links a:hover,.nav-links a.active{color:var(--text)}
    .hamburger{display:none;flex-direction:column;gap:4px;cursor:pointer;padding:4px}
    .hamburger span{width:20px;height:1.5px;background:var(--text);display:block}
    .mobile-menu{display:none;position:fixed;inset:0;background:var(--surface);z-index:99;padding:5rem 2rem 2rem;flex-direction:column;gap:1.5rem}
    .mobile-menu.open{display:flex}
    .mobile-menu a{font-size:22px;font-family:'Playfair Display',serif;color:var(--text)}
    .mobile-close{position:absolute;top:1.25rem;right:2rem;font-size:24px;cursor:pointer;color:var(--text2)}
    @media(max-width:600px){.nav-links{display:none}.hamburger{display:flex}}
    .page-header{max-width:960px;margin:0 auto;padding:2rem 2rem 1rem;display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:10px}
    .page-title{font-family:'Playfair Display',serif;font-size:28px;font-weight:400;letter-spacing:-.8px}
    .page-meta{font-size:13px;color:var(--text2)}
    .voter-bar{background:var(--accent-bg);border-bottom:0.5px solid var(--accent-brd);padding:9px 2rem;font-size:13px;color:var(--accent)}
    .phase-note{background:#f5f4f0;border-bottom:0.5px solid var(--border);padding:9px 2rem;font-size:13px;color:var(--text2)}
    .gallery-wrap{max-width:960px;margin:0 auto;padding:0 2rem 3rem}
    .gallery-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px;margin-top:1.25rem}
    .card{background:var(--surface);border:0.5px solid var(--border);border-radius:var(--r);overflow:hidden;transition:transform .2s,box-shadow .2s;cursor:pointer}
    .card:hover{transform:translateY(-2px);box-shadow:0 4px 16px rgba(0,0,0,.07)}
    .thumb{aspect-ratio:3/4;overflow:hidden;background:var(--bg);display:flex;align-items:center;justify-content:center;position:relative}
    .thumb img{width:100%;height:100%;object-fit:cover;transition:transform .4s}
    .card:hover .thumb img{transform:scale(1.03)}
    .voted-tag{position:absolute;top:8px;right:8px;background:var(--accent);color:#fff;font-size:10px;padding:3px 8px;border-radius:20px}
    .card-info{padding:10px 12px;border-top:0.5px solid var(--border)}
    .card-num{font-size:11px;color:var(--text3);letter-spacing:.5px;text-transform:uppercase}
    .empty{text-align:center;padding:5rem 2rem;color:var(--text2)}
    footer{background:var(--surface);border-top:0.5px solid var(--border);margin-top:2rem}
    .footer-inner{max-width:960px;margin:0 auto;padding:1.5rem 2rem;display:flex;align-items:center;justify-content:space-between}
    .footer-logo{font-family:'Playfair Display',serif;font-size:14px}
    .footer-links{display:flex;gap:1.5rem}
    .footer-links a{font-size:12px;color:var(--text2)}
    .footer-links a:hover{color:var(--text)}

    /* LIGHTBOX */
    .lb-wrap{display:none;position:fixed;inset:0;background:rgba(0,0,0,.94);z-index:300;align-items:stretch;justify-content:center}
    .lb-wrap.open{display:flex}
    .lb-close{position:absolute;top:1rem;right:1.25rem;color:#fff;font-size:26px;cursor:pointer;opacity:.6;transition:opacity .15s;z-index:2;line-height:1;background:none;border:none}
    .lb-close:hover{opacity:1}
    .lb-arrow{position:absolute;top:50%;transform:translateY(-50%);color:#fff;font-size:28px;cursor:pointer;opacity:.5;transition:opacity .15s;background:none;border:none;padding:1rem;z-index:2}
    .lb-arrow:hover{opacity:1}
    .lb-prev{left:0}
    .lb-next{right:0}
    .lb-counter{position:absolute;top:1rem;left:50%;transform:translateX(-50%);color:rgba(255,255,255,.4);font-size:12px;letter-spacing:1px}
    .lb-inner{display:flex;align-items:center;justify-content:center;width:100%;padding:3rem 5rem;gap:3rem}
    @media(max-width:700px){.lb-inner{flex-direction:column;padding:3rem 1.5rem;gap:1.5rem}}
    .lb-photo{flex-shrink:0;max-width:min(420px,50vw);max-height:80vh}
    .lb-photo img{max-width:100%;max-height:80vh;object-fit:contain;border-radius:var(--r);display:block}
    @media(max-width:700px){.lb-photo{max-width:100%;max-height:45vh}}
    .lb-panel{width:280px;flex-shrink:0;display:flex;flex-direction:column;gap:1rem}
    @media(max-width:700px){.lb-panel{width:100%}}
    .lb-num{font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:4px}
    .lb-voted-badge{display:inline-flex;align-items:center;gap:5px;background:rgba(15,110,86,.25);border:0.5px solid rgba(93,202,165,.4);color:#5DCAA5;font-size:12px;padding:4px 12px;border-radius:20px;margin-bottom:8px}

    /* Vote form in lightbox */
    .lb-vote-form{background:rgba(255,255,255,.07);border-radius:var(--r);padding:1rem}
    .lb-vote-label{font-size:12px;color:rgba(255,255,255,.5);letter-spacing:.5px;text-transform:uppercase;margin-bottom:8px;display:block}
    .lb-email-input{width:100%;padding:9px 12px;font-size:14px;border:0.5px solid rgba(255,255,255,.2);border-radius:var(--r);background:rgba(255,255,255,.08);color:#fff;font-family:'Inter',sans-serif;margin-bottom:8px}
    .lb-email-input::placeholder{color:rgba(255,255,255,.3)}
    .lb-email-input:focus{outline:none;border-color:rgba(255,255,255,.4)}
    .lb-vote-btn{width:100%;padding:10px;background:#fff;color:#1a1a18;border:none;border-radius:var(--r);font-size:13px;font-weight:500;cursor:pointer;font-family:'Inter',sans-serif;transition:opacity .15s;display:flex;align-items:center;justify-content:center;gap:6px}
    .lb-vote-btn:hover{opacity:.9}
    .lb-vote-btn:disabled{opacity:.5;cursor:wait}
    .lb-vote-btn.voted{background:rgba(15,110,86,.3);color:#5DCAA5;border:0.5px solid rgba(93,202,165,.4)}
    .lb-err{font-size:12px;color:#f09595;margin-top:6px;display:none}
    .lb-success{font-size:13px;color:#5DCAA5;display:none;align-items:center;gap:6px;margin-top:6px}

    /* Switch vote confirm */
    .lb-switch-box{background:rgba(255,255,255,.07);border:0.5px solid rgba(255,255,255,.15);border-radius:var(--r);padding:1rem;display:none}
    .lb-switch-box.show{display:block}
    .lb-switch-text{font-size:13px;color:rgba(255,255,255,.85);line-height:1.5;margin-bottom:10px}
    .lb-switch-actions{display:flex;gap:8px}
    .lb-btn-yes{flex:1;padding:8px;background:#fff;color:#1a1a18;border:none;border-radius:var(--r);font-size:13px;font-weight:500;cursor:pointer;font-family:'Inter',sans-serif}
    .lb-btn-no{flex:1;padding:8px;background:transparent;color:rgba(255,255,255,.6);border:0.5px solid rgba(255,255,255,.2);border-radius:var(--r);font-size:13px;cursor:pointer;font-family:'Inter',sans-serif}

    /* Share */
    .lb-share{border-top:0.5px solid rgba(255,255,255,.1);padding-top:1rem;margin-top:.5rem}
    .lb-share-text{font-size:13px;color:rgba(255,255,255,.6);margin-bottom:8px;line-height:1.5}
    .lb-share-link{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.07);border:0.5px solid rgba(255,255,255,.15);border-radius:var(--r);padding:8px 12px}
    .lb-share-url{font-size:12px;color:rgba(255,255,255,.5);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-family:monospace}
    .lb-copy-btn{font-size:11px;color:#fff;background:rgba(255,255,255,.15);border:none;border-radius:4px;padding:4px 10px;cursor:pointer;font-family:'Inter',sans-serif;white-space:nowrap;transition:background .15s}
    .lb-copy-btn:hover{background:rgba(255,255,255,.25)}

    .toast{position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(20px);background:var(--text);color:var(--bg);padding:10px 22px;border-radius:50px;font-size:13px;font-weight:500;opacity:0;transition:all .3s;pointer-events:none;z-index:400;white-space:nowrap}
    .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
  </style>
</head>
<body>
<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo"><%= settings.footer_text||'Jan Svoboda Photography' %></a>
    <div class="nav-links">
      <a href="/">Domů</a>
      <a href="/galerie" class="active">Galerie</a>
      <a href="/pravidla">Pravidla</a>
      <% if(typeof isAdmin!=='undefined'&&isAdmin){%><a href="/admin">Admin</a><%}%>
    </div>
    <div class="hamburger" onclick="openMenu()"><span></span><span></span><span></span></div>
  </div>
</nav>
<div class="mobile-menu" id="mm">
  <span class="mobile-close" onclick="closeMenu()">✕</span>
  <a href="/" onclick="closeMenu()">Domů</a>
  <a href="/galerie" onclick="closeMenu()">Galerie</a>
  <a href="/pravidla" onclick="closeMenu()">Pravidla</a>
  <% if(typeof isAdmin!=='undefined'&&isAdmin){%><a href="/admin" onclick="closeMenu()">Admin</a><%}%>
</div>

<% if(settings.phase==='voting'){ %>
  <% if(voterEmail){ %>
    <div class="voter-bar">✓ Hlasujete jako <strong style="margin:0 3px"><%= voterEmail %></strong><% if(votedFor){%> — hlas odevzdán<%}%></div>
  <% }else{ %>
    <div class="voter-bar">🗳 Klikněte na fotografii pro hlasování.</div>
  <% }%>
<% }else if(settings.phase==='registration'){ %>
  <div class="phase-note">Přihlašování stále probíhá. Hlasování bude spuštěno brzy.</div>
<% }else{ %>
  <div class="phase-note">Hlasování ukončeno. <a href="/vysledky" style="color:var(--text);font-weight:500;text-decoration:underline">Výsledky →</a></div>
<% }%>

<div class="gallery-wrap">
  <div class="page-header" style="padding-left:0;padding-right:0">
    <h1 class="page-title"><%= settings.gallery_title||'Galerie fotografií' %></h1>
    <span class="page-meta"><%= entries.length %> snímků</span>
  </div>
  <% if(entries.length===0){ %>
    <div class="empty">Zatím žádné schválené fotografie.</div>
  <% }else{ %>
  <div class="gallery-grid">
    <% entries.forEach((e,idx)=>{ const isVoted=votedFor===e.id; %>
    <div class="card" onclick="openLB(<%= idx %>)">
      <div class="thumb">
        <img src="/uploads/<%= e.photo %>" alt="Zadeček č. <%= e.anon_number %>" loading="lazy">
        <% if(isVoted){%><span class="voted-tag">✓ Váš hlas</span><%}%>
      </div>
      <div class="card-info">
        <div class="card-num">Zadeček č. <%= e.anon_number %></div>
      </div>
    </div>
    <%})%>
  </div>
  <%}%>
</div>

<!-- LIGHTBOX -->
<div class="lb-wrap" id="lb-wrap">
  <button class="lb-close" onclick="closeLB()">✕</button>
  <button class="lb-arrow lb-prev" onclick="prevLB()">‹</button>
  <button class="lb-arrow lb-next" onclick="nextLB()">›</button>
  <div class="lb-counter" id="lb-counter"></div>
  <div class="lb-inner">
    <div class="lb-photo"><img id="lb-img" src="" alt=""></div>
    <div class="lb-panel">
      <div>
        <div class="lb-num" id="lb-num"></div>
        <div id="lb-voted-badge" class="lb-voted-badge" style="display:none">✓ Váš hlas</div>
      </div>

      <!-- Vote form -->
      <% if(settings.phase==='voting'){ %>
      <div class="lb-vote-form" id="lb-vote-form">
        <label class="lb-vote-label">Hlasovat</label>
        <input type="email" class="lb-email-input" id="lb-email" placeholder="vas@email.cz" value="<%= voterEmail||'' %>">
        <button class="lb-vote-btn" id="lb-vote-btn" onclick="lbVote()">♡ Hlasovat</button>
        <div class="lb-err" id="lb-err"></div>
        <div class="lb-success" id="lb-success">✓ Hlas byl zaznamenán!</div>
        <!-- Switch vote confirm -->
        <div class="lb-switch-box" id="lb-switch-box">
          <div class="lb-switch-text" id="lb-switch-text"></div>
          <div class="lb-switch-actions">
            <button class="lb-btn-yes" onclick="lbSwitchConfirm()">Ano, změnit hlas</button>
            <button class="lb-btn-no" onclick="hideSwitchBox()">Ne, ponechat</button>
          </div>
        </div>
      </div>
      <% } %>

      <!-- Share -->
      <div class="lb-share">
        <div class="lb-share-text">Líbí se ti tento zadeček? Sdílej ho!</div>
        <div class="lb-share-link">
          <span class="lb-share-url" id="lb-share-url"></span>
          <button class="lb-copy-btn" onclick="copyLink()"><i class="ti ti-copy" aria-hidden="true"></i> Kopírovat</button>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>
<footer>
  <div class="footer-inner">
    <div class="footer-logo"><%= settings.footer_text||'Jan Svoboda Photography' %></div>
    <div class="footer-links"><a href="/pravidla">Pravidla</a><a href="/admin/login">Admin</a></div>
  </div>
</footer>

<script>
const entries = <%- JSON.stringify(entries.map(e=>({id:e.id,photo:e.photo,anon:e.anon_number,voted:<%= JSON.stringify(votedFor) %>===e.id}))) %>;
const votingOpen = <%= settings.phase==='voting'?'true':'false' %>;
const appUrl = window.location.origin;
let currentIdx = 0;
let pendingSwitch = null;

function openMenu(){document.getElementById('mm').classList.add('open');document.body.style.overflow='hidden';}
function closeMenu(){document.getElementById('mm').classList.remove('open');document.body.style.overflow='';}

function openLB(idx) {
  currentIdx = idx;
  renderLB();
  document.getElementById('lb-wrap').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeLB() {
  document.getElementById('lb-wrap').classList.remove('open');
  document.body.style.overflow = '';
}
function prevLB() { currentIdx = (currentIdx - 1 + entries.length) % entries.length; renderLB(); }
function nextLB() { currentIdx = (currentIdx + 1) % entries.length; renderLB(); }

function renderLB() {
  const e = entries[currentIdx];
  document.getElementById('lb-img').src = '/uploads/' + e.photo;
  document.getElementById('lb-num').textContent = 'Zadeček č. ' + e.anon;
  document.getElementById('lb-counter').textContent = (currentIdx+1) + ' / ' + entries.length;
  document.getElementById('lb-share-url').textContent = appUrl + '/zadecek/' + e.id;
  document.getElementById('lb-voted-badge').style.display = e.voted ? 'inline-flex' : 'none';
  // Reset vote form
  const errEl = document.getElementById('lb-err');
  const sucEl = document.getElementById('lb-success');
  const btn = document.getElementById('lb-vote-btn');
  if(errEl) errEl.style.display = 'none';
  if(sucEl) sucEl.style.display = 'none';
  hideSwitchBox();
  if(btn) {
    btn.disabled = false;
    if(e.voted) {
      btn.className = 'lb-vote-btn voted';
      btn.textContent = '♥ Hlasováno';
    } else {
      btn.className = 'lb-vote-btn';
      btn.textContent = '♡ Hlasovat';
    }
  }
}

function hideSwitchBox() {
  const sb = document.getElementById('lb-switch-box');
  if(sb) { sb.classList.remove('show'); pendingSwitch = null; }
}

async function lbVote() {
  const email = (document.getElementById('lb-email').value||'').trim();
  const errEl = document.getElementById('lb-err');
  const sucEl = document.getElementById('lb-success');
  const btn = document.getElementById('lb-vote-btn');
  if(!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
    errEl.textContent = 'Zadejte platný e-mail.'; errEl.style.display='block'; return;
  }
  btn.disabled = true; btn.textContent = 'Odesílám...';
  errEl.style.display = 'none';
  const e = entries[currentIdx];
  try {
    const r = await fetch('/hlasovat', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({entry_id:e.id,voter_email:email})});
    const data = await r.json();
    if(!data.ok) {
      if(data.canSwitch) {
        // Show switch confirm
        btn.disabled = false; btn.textContent = '♡ Hlasovat';
        const sb = document.getElementById('lb-switch-box');
        document.getElementById('lb-switch-text').textContent = data.error;
        pendingSwitch = {email, newId: e.id, oldId: data.oldEntryId};
        sb.classList.add('show');
      } else {
        errEl.textContent = data.error; errEl.style.display='block';
        btn.disabled = false; btn.textContent = '♡ Hlasovat';
      }
      return;
    }
    // Success
    e.voted = true;
    btn.className = 'lb-vote-btn voted'; btn.textContent = '♥ Hlasováno'; btn.disabled = false;
    sucEl.style.display = 'flex';
    document.getElementById('lb-voted-badge').style.display = 'inline-flex';
    // Update grid card
    updateGridCard(e.id, true);
    if(data.oldEntryId) updateGridCard(data.oldEntryId, false);
  } catch { errEl.textContent='Chyba připojení.'; errEl.style.display='block'; btn.disabled=false; btn.textContent='♡ Hlasovat'; }
}

async function lbSwitchConfirm() {
  if(!pendingSwitch) return;
  const {email, newId, oldId} = pendingSwitch;
  hideSwitchBox();
  const btn = document.getElementById('lb-vote-btn');
  btn.disabled = true; btn.textContent = 'Odesílám...';
  try {
    const r = await fetch('/hlasovat-prepsat', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({entry_id:newId,voter_email:email})});
    const data = await r.json();
    if(!data.ok) { document.getElementById('lb-err').textContent=data.error; document.getElementById('lb-err').style.display='block'; btn.disabled=false; btn.textContent='♡ Hlasovat'; return; }
    entries[currentIdx].voted = true;
    btn.className='lb-vote-btn voted'; btn.textContent='♥ Hlasováno'; btn.disabled=false;
    document.getElementById('lb-success').style.display='flex';
    document.getElementById('lb-voted-badge').style.display='inline-flex';
    updateGridCard(newId, true);
    if(oldId) { updateGridCard(oldId, false); entries.find(e=>e.id===oldId&&(e.voted=false)); }
    showToast('✓ Hlas byl změněn!');
  } catch { document.getElementById('lb-err').textContent='Chyba.'; document.getElementById('lb-err').style.display='block'; btn.disabled=false; btn.textContent='♡ Hlasovat'; }
}

function updateGridCard(id, isVoted) {
  const cards = document.querySelectorAll('.card');
  entries.forEach((e,i)=>{
    if(e.id===id){
      const thumb = cards[i]?.querySelector('.thumb');
      if(!thumb) return;
      let tag = thumb.querySelector('.voted-tag');
      if(isVoted && !tag){ tag=document.createElement('span'); tag.className='voted-tag'; tag.textContent='✓ Váš hlas'; thumb.appendChild(tag); }
      else if(!isVoted && tag){ tag.remove(); }
    }
  });
}

function copyLink() {
  const url = appUrl + '/zadecek/' + entries[currentIdx].id;
  navigator.clipboard.writeText(url).then(()=>showToast('✓ Odkaz zkopírován!')).catch(()=>{});
}

function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),3000);}

document.addEventListener('keydown', e => {
  if(!document.getElementById('lb-wrap').classList.contains('open')) return;
  if(e.key==='Escape') closeLB();
  if(e.key==='ArrowLeft') prevLB();
  if(e.key==='ArrowRight') nextLB();
});
</script>
</body>
</html>
