<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin přihlášení</title>
  <style>
    *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
    body { font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; background:#fafaf9; display:flex; align-items:center; justify-content:center; min-height:100vh; }
    .card { background:#fff; border:0.5px solid rgba(0,0,0,0.1); border-radius:12px; padding:2rem; width:100%; max-width:360px; }
    h1 { font-size:18px; font-weight:500; margin-bottom:1.5rem; }
    label { font-size:12px; color:#5a5955; font-weight:500; display:block; margin-bottom:5px; }
    input { width:100%; padding:9px 12px; font-size:14px; border:0.5px solid rgba(0,0,0,0.2); border-radius:7px; background:#fafaf9; color:#1a1a18; margin-bottom:14px; font-family:inherit; }
    input:focus { outline:none; border-color:#1a1a18; }
    button { width:100%; padding:10px; background:#1a1a18; color:#fff; border:none; border-radius:7px; font-size:14px; font-weight:500; cursor:pointer; font-family:inherit; transition:opacity .15s; }
    button:hover { opacity:.85; }
    .error { background:#FCEBEB; color:#A32D2D; padding:8px 12px; border-radius:7px; font-size:13px; margin-bottom:14px; }
  </style>
</head>
<body>
<div class="card">
  <h1>🔐 Admin přihlášení</h1>
  <% if (error) { %><div class="error"><%= error %></div><% } %>
  <form action="/admin/login" method="POST">
    <label>Uživatelské jméno</label>
    <input type="text" name="username" required autofocus autocomplete="username">
    <label>Heslo</label>
    <input type="password" name="password" required autocomplete="current-password">
    <button type="submit">Přihlásit se →</button>
  </form>
</div>
</body>
</html>
