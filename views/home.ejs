<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= settings.contest_title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{--bg:<%= settings.color_bg||'#fafaf8' %>;--surface:#fff;--text:<%= settings.color_primary||'#1a1a18' %>;--text2:#5a5955;--text3:#9a9893;--border:rgba(0,0,0,0.09);--border2:rgba(0,0,0,0.18);--accent:<%= settings.color_accent||'#0F6E56' %>;--accent-bg:#E1F5EE;--accent-brd:#5DCAA5;--amber:#854F0B;--amber-bg:#FAEEDA;--amber-brd:#FAC775;--red:#A32D2D;--red-bg:#FCEBEB;--r:6px}
    body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh}
    a{color:inherit;text-decoration:none}

    nav{background:var(--surface);border-bottom:0.5px solid var(--border);position:sticky;top:0;z-index:100}
    .nav-inner{max-width:720px;margin:0 auto;padding:0 2rem;height:56px;display:flex;align-items:center;justify-content:space-between}
    .nav-logo{font-family:'Playfair Display',serif;font-size:16px}
    .nav-logo em{font-style:italic;color:var(--text2)}
    .nav-links{display:flex;gap:1.5rem}
    .nav-links a{font-size:12px;color:var(--text2);letter-spacing:.5px;text-transform:uppercase;transition:color .2s}
    .nav-links a:hover,.nav-links a.active{color:var(--text)}

    .wrap{max-width:720px;margin:0 auto;padding:0 2rem}

    .alert{padding:10px 16px;border-radius:var(--r);font-size:14px;margin:1rem auto;max-width:720px;margin-left:auto;margin-right:auto}
    .alert{padding:10px 2rem;font-size:14px;border-bottom:0.5px solid var(--border)}
    .alert-success{background:var(--accent-bg);color:var(--accent)}
    .alert-error{background:var(--red-bg);color:var(--red)}

    .hero{padding:4rem 2rem 3rem;max-width:720px;margin:0 auto;border-bottom:0.5px solid var(--border)}
    .hero-eyebrow{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--text2);margin-bottom:1.25rem}
    .hero-title{font-family:'Playfair Display',serif;font-size:48px;line-height:1.08;letter-spacing:-1.5px;margin-bottom:1.25rem;font-weight:400}
    .hero-title em{font-style:italic;color:var(--text2)}
    .hero-desc{font-size:15px;color:var(--text2);line-height:1.75;max-width:480px;margin-bottom:2rem}
    .hero-cta{display:flex;gap:14px;align-items:center;flex-wrap:wrap}
    .btn-dark{background:var(--text);color:var(--bg);padding:11px 24px;border-radius:var(--r);font-size:13px;font-weight:500;cursor:pointer;border:none;font-family:'Inter',sans-serif;transition:opacity .15s;display:inline-block}
    .btn-dark:hover{opacity:.85}
    .btn-ghost{font-size:13px;color:var(--text2);cursor:pointer;transition:color .2s}
    .btn-ghost:hover{color:var(--text)}

    .phase-banner{max-width:720px;margin:0 auto;padding:1rem 2rem;border-bottom:0.5px solid var(--border)}
    .pb-vote{background:var(--accent-bg);color:var(--accent)}
    .pb-done{background:#f1f0ec;color:var(--text2)}
    .pb-vote a,.pb-done a{font-weight:500;text-decoration:underline}

    .form-section{max-width:720px;margin:0 auto;padding:2.5rem 2rem}
    .section-label{font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:var(--text2);margin-bottom:1.5rem;font-weight:500}
    .upload-zone{border:1px dashed var(--border2);border-radius:var(--r);padding:2.5rem 2rem;text-align:center;cursor:pointer;transition:all .2s;margin-bottom:1.5rem;background:var(--surface)}
    .upload-zone:hover{border-color:var(--text3);background:#f7f6f2}
    .upload-zone.has-file{border-color:var(--accent);border-style:solid;background:var(--accent-bg)}
    .upload-icon{font-size:28px;margin-bottom:10px;opacity:.35}
    .upload-zone p{font-size:14px;color:var(--text2);margin-bottom:4px}
    .upload-zone small{font-size:12px;color:var(--text3)}
    #preview-img{max-height:220px;border-radius:var(--r);margin-top:1rem;border:0.5px solid var(--border);display:none}
    .mobile-hint{font-size:12px;color:var(--accent);margin-top:6px;display:none}
    .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
    @media(max-width:520px){.form-grid{grid-template-columns:1fr}.mobile-hint{display:block}}
    label{font-size:11px;color:var(--text2);font-weight:500;display:block;margin-bottom:6px;letter-spacing:.4px;text-transform:uppercase}
    input[type=text],input[type=email],textarea{width:100%;padding:10px 14px;font-size:14px;border:0.5px solid var(--border2);border-radius:var(--r);background:var(--surface);color:var(--text);font-family:'Inter',sans-serif;transition:border-color .15s}
    input:focus,textarea:focus{outline:none;border-color:var(--text)}
    textarea{resize:vertical;min-height:80px}
    .form-footer{display:flex;align-items:center;justify-content:space-between;margin-top:6px;flex-wrap:wrap;gap:10px}
    .form-note{font-size:12px;color:var(--text3)}

    .stats{display:grid;grid-template-columns:repeat(3,1fr);border-top:0.5px solid var(--border);border-bottom:0.5px solid var(--border);background:var(--surface);max-width:720px;margin:0 auto}
    .stat{padding:1.25rem 2rem;border-right:0.5px solid var(--border)}
    .stat:last-child{border-right:none}
    .stat-num{font-family:'Playfair Display',serif;font-size:28px;font-weight:400;letter-spacing:-.5px;line-height:1}
    .stat-label{font-size:11px;color:var(--text2);margin-top:4px;letter-spacing:.5px;text-transform:uppercase}

    .prizes{display:grid;grid-template-columns:repeat(3,1fr);border-top:0.5px solid var(--border);max-width:720px;margin:0 auto;background:var(--surface)}
    .prize{padding:1.5rem 2rem;border-right:0.5px solid var(--border)}
    .prize:last-child{border-right:none}
    .prize-icon{font-size:18px;margin-bottom:8px;opacity:.5}
    .prize-title{font-size:14px;font-weight:500;margin-bottom:3px}
    .prize-desc{font-size:13px;color:var(--text2)}

    footer{background:var(--surface);border-top:0.5px solid var(--border);margin-top:3rem}
    .footer-inner{max-width:720px;margin:0 auto;padding:1.5rem 2rem;display:flex;align-items:center;justify-content:space-between}
    .footer-logo{font-family:'Playfair Display',serif;font-size:14px}
    .footer-links{display:flex;gap:1.5rem}
    .footer-links a{font-size:12px;color:var(--text2)}
    .footer-links a:hover{color:var(--text)}
  </style>
</head>
<body>
<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">Jan Svoboda <em>Photography</em></a>
    <div class="nav-links">
      <a href="/" class="active">Domů</a>
      <a href="/galerie">Galerie</a>
      <a href="/vysledky">Výsledky</a>
      <a href="/pravidla">Pravidla</a>
      <% if (typeof isAdmin !== 'undefined' && isAdmin) { %><a href="/admin">Admin</a><% } %>
    </div>
  </div>
</nav>

<% if (success) { %><div class="alert alert-success">✓ <%- decodeURIComponent((success||'').replace(/\+/g,' ')) %></div><% } %>
<% if (error) { %><div class="alert alert-error">⚠ <%- decodeURIComponent((error||'').replace(/\+/g,' ')) %></div><% } %>

<div class="hero">
  <div class="hero-eyebrow">
    Ročník 2026 &nbsp;·&nbsp;
    <% if(settings.phase==='registration'){%>Přihlášky do <%= settings.registration_end %>
    <%}else if(settings.phase==='voting'){%>Hlasování do <%= settings.voting_end %>
    <%}else{%>Soutěž ukončena<%}%>
  </div>
  <h1 class="hero-title">Soutěž<br>o nejhezčí<br><em>portrét</em></h1>
  <p class="hero-desc"><%= settings.home_subtitle || 'Pošlete svůj nejlepší portrétní snímek. Veřejnost hlasuje – vítěz získá profesionální focení zdarma.' %></p>
  <div class="hero-cta">
    <% if(settings.phase==='registration'){ %>
      <button class="btn-dark" onclick="document.getElementById('upload-zone').scrollIntoView({behavior:'smooth'})">Přihlásit fotografii</button>
      <a href="/galerie" class="btn-ghost">Zobrazit galerii →</a>
    <% }else if(settings.phase==='voting'){ %>
      <a href="/galerie" class="btn-dark">Hlasovat v galerii</a>
      <a href="/vysledky" class="btn-ghost">Průběžné výsledky →</a>
    <% }else{ %>
      <a href="/vysledky" class="btn-dark">Zobrazit výsledky</a>
    <% } %>
  </div>
</div>

<div class="stats">
  <div class="stat"><div class="stat-num"><%= settings.registration_end %></div><div class="stat-label">Uzávěrka přihlášek</div></div>
  <div class="stat"><div class="stat-num"><%= settings.voting_end %></div><div class="stat-label">Uzávěrka hlasování</div></div>
  <div class="stat"><div class="stat-num">1×</div><div class="stat-label">Fotografie na účastníka</div></div>
</div>

<% if(settings.phase==='registration'){ %>
<div class="form-section">
  <div class="section-label">Přihlásit fotografii</div>
  <div class="upload-zone" id="upload-zone" onclick="document.getElementById('photo').click()">
    <div class="upload-icon">↑</div>
    <p>Klikněte nebo přetáhněte fotografii</p>
    <small>JPG, PNG, WebP – max. 15 MB · Funguje i z mobilu 📱</small>
    <div class="mobile-hint">📱 Na mobilu můžete vyfotit přímo nebo vybrat z galerie</div>
    <img id="preview-img" alt="Náhled">
  </div>
  <form action="/prihlasit" method="POST" enctype="multipart/form-data">
    <input type="file" name="photo" id="photo" accept="image/*" style="display:none" required onchange="handleFile(this)">
    <div class="form-grid">
      <div><label>Jméno a příjmení *</label><input type="text" name="name" required placeholder="Jana Nováková"></div>
      <div><label>E-mail *</label><input type="email" name="email" required placeholder="jana@email.cz"></div>
    </div>
    <div style="margin-bottom:1.25rem"><label>Krátké představení</label><textarea name="note" placeholder="Pár slov o sobě..." maxlength="300"></textarea></div>
    <div class="form-footer">
      <span class="form-note">Odesláním souhlasíte se zveřejněním fotografie v galerii. Každý může přihlásit pouze jednu fotografii.</span>
      <button type="submit" class="btn-dark">Odeslat →</button>
    </div>
  </form>
</div>
<% }else if(settings.phase==='voting'){ %>
<div class="phase-banner pb-vote">
  🗳 Hlasování je otevřeno. <a href="/galerie">Přejít do galerie →</a>
</div>
<% }else{ %>
<div class="phase-banner pb-done">
  🏁 Hlasování ukončeno. <a href="/vysledky">Zobrazit výsledky →</a>
</div>
<% } %>

<div class="prizes">
  <div class="prize"><div class="prize-icon">🏆</div><div class="prize-title">1. místo</div><div class="prize-desc"><%= settings.prize_description %></div></div>
  <div class="prize"><div class="prize-icon">✉</div><div class="prize-title">Hlasování</div><div class="prize-desc">Každý e-mail = 1 hlas</div></div>
  <div class="prize"><div class="prize-icon">🔒</div><div class="prize-title">Anonymita</div><div class="prize-desc">Účastníci jsou anonymní</div></div>
</div>

<footer>
  <div class="footer-inner">
    <div class="footer-logo">Jan Svoboda Photography</div>
    <div class="footer-links">
      <a href="/pravidla">Pravidla</a>
      <a href="/galerie">Galerie</a>
      <a href="/admin/login">Admin</a>
    </div>
  </div>
</footer>

<script>
const zone = document.getElementById('upload-zone');
if(zone){
  zone.addEventListener('dragover',e=>e.preventDefault());
  zone.addEventListener('drop',e=>{e.preventDefault();const f=e.dataTransfer.files[0];if(f){const dt=new DataTransfer();dt.items.add(f);document.getElementById('photo').files=dt.files;handleFile(document.getElementById('photo'));}});
}
function handleFile(input){
  if(!input.files[0])return;
  const reader=new FileReader();
  reader.onload=e=>{const img=document.getElementById('preview-img');img.src=e.target.result;img.style.display='block';document.getElementById('upload-zone').classList.add('has-file');};
  reader.readAsDataURL(input.files[0]);
}
</script>
</body>
</html>
