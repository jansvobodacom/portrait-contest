<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= settings.contest_title %></title>
  <!-- OG tagy -->
  <meta property="og:title" content="<%= settings.contest_title %>">
  <meta property="og:description" content="<%= settings.home_subtitle || 'Hlasujte pro nejhezčí portrét!' %>">
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= process.env.APP_URL || '' %>/">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= settings.contest_title %>">
  <meta name="twitter:description" content="<%= settings.home_subtitle || 'Hlasujte pro nejhezčí portrét!' %>">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{--bg:<%= settings.color_bg||'#fafaf8' %>;--surface:#fff;--text:<%= settings.color_primary||'#1a1a18' %>;--text2:#5a5955;--text3:#9a9893;--border:rgba(0,0,0,0.09);--border2:rgba(0,0,0,0.18);--accent:<%= settings.color_accent||'#0F6E56' %>;--accent-bg:#E1F5EE;--accent-brd:#5DCAA5;--amber:#854F0B;--amber-bg:#FAEEDA;--amber-brd:#FAC775;--red:#A32D2D;--red-bg:#FCEBEB;--r:6px}
    body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh}
    a{color:inherit;text-decoration:none}
    nav{background:var(--surface);border-bottom:0.5px solid var(--border);position:sticky;top:0;z-index:100}
    .nav-inner{max-width:720px;margin:0 auto;padding:0 2rem;height:56px;display:flex;align-items:center;justify-content:space-between}
    .nav-logo{font-family:'Playfair Display',serif;font-size:16px}
    .nav-logo em{font-style:italic;color:var(--text2)}
    .nav-links{display:flex;gap:1.5rem}
    .nav-links a{font-size:12px;color:var(--text2);letter-spacing:.5px;text-transform:uppercase;transition:color .2s}
    .nav-links a:hover,.nav-links a.active{color:var(--text)}
    .hamburger{display:none;flex-direction:column;gap:4px;cursor:pointer;padding:4px}
    .hamburger span{width:20px;height:1.5px;background:var(--text);display:block}
    .mobile-menu{display:none;position:fixed;inset:0;background:var(--surface);z-index:99;padding:5rem 2rem 2rem;flex-direction:column;gap:1.5rem}
    .mobile-menu.open{display:flex}
    .mobile-menu a{font-size:22px;font-family:'Playfair Display',serif;color:var(--text)}
    .mobile-close{position:absolute;top:1.25rem;right:2rem;font-size:24px;cursor:pointer;color:var(--text2)}
    @media(max-width:600px){.nav-links{display:none}.hamburger{display:flex}}
    .alert{font-size:14px;padding:10px 2rem;border-bottom:0.5px solid var(--border)}
    .alert-success{background:var(--accent-bg);color:var(--accent)}
    .alert-error{background:var(--red-bg);color:var(--red)}
    .hero{max-width:720px;margin:0 auto;padding:3.5rem 2rem 2.5rem;border-bottom:0.5px solid var(--border)}
    .hero-eyebrow{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--text2);margin-bottom:1.25rem}
    .hero-title{font-family:'Playfair Display',serif;font-size:48px;line-height:1.08;letter-spacing:-1.5px;margin-bottom:1.25rem;font-weight:400}
    .hero-title em{font-style:italic;color:var(--text2)}
    .hero-desc{font-size:15px;color:var(--text2);line-height:1.75;max-width:480px;margin-bottom:1.5rem}
    /* Countdown */
    .countdown{display:flex;gap:1.5rem;margin-bottom:2rem;align-items:flex-end}
    .cd-unit{text-align:center}
    .cd-num{font-family:'Playfair Display',serif;font-size:36px;font-weight:400;line-height:1;letter-spacing:-1px}
    .cd-label{font-size:10px;color:var(--text3);letter-spacing:1px;text-transform:uppercase;margin-top:3px}
    .cd-sep{font-family:'Playfair Display',serif;font-size:28px;color:var(--text3);margin-bottom:6px}
    .hero-cta{display:flex;gap:14px;align-items:center;flex-wrap:wrap}
    .btn-dark{background:var(--text);color:var(--bg);padding:11px 24px;border-radius:var(--r);font-size:13px;font-weight:500;cursor:pointer;border:none;font-family:'Inter',sans-serif;transition:opacity .15s;display:inline-block}
    .btn-dark:hover{opacity:.85}
    .btn-ghost{font-size:13px;color:var(--text2);cursor:pointer;transition:color .2s}
    .btn-ghost:hover{color:var(--text)}
    /* Header foto */
    .header-photo{width:100%;max-height:400px;object-fit:cover;display:block;border-bottom:0.5px solid var(--border)}
    /* Stats */
    .stats{display:grid;grid-template-columns:repeat(3,1fr);border-top:0.5px solid var(--border);border-bottom:0.5px solid var(--border);background:var(--surface);max-width:720px;margin:0 auto}
    .stat{padding:1.25rem 2rem;border-right:0.5px solid var(--border)}
    .stat:last-child{border-right:none}
    .stat-num{font-family:'Playfair Display',serif;font-size:26px;font-weight:400;letter-spacing:-.5px;line-height:1}
    .stat-label{font-size:11px;color:var(--text2);margin-top:4px;letter-spacing:.5px;text-transform:uppercase}
    /* Upload form */
    .form-section{max-width:720px;margin:0 auto;padding:2.5rem 2rem}
    .section-label{font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:var(--text2);margin-bottom:1.5rem;font-weight:500}
    .upload-zone{border:1px dashed var(--border2);border-radius:var(--r);padding:2rem;text-align:center;cursor:pointer;transition:all .2s;margin-bottom:1.5rem;background:var(--surface)}
    .upload-zone:hover{border-color:var(--text3)}
    .upload-zone.has-file{border-color:var(--accent);border-style:solid}
    .upload-icon{font-size:24px;margin-bottom:8px;opacity:.3}
    .upload-zone p{font-size:14px;color:var(--text2);margin-bottom:3px}
    .upload-zone small{font-size:12px;color:var(--text3)}
    #preview-img{max-height:220px;border-radius:var(--r);margin-top:1rem;border:0.5px solid var(--border);display:none}
    /* Preview card */
    .preview-card{display:none;background:var(--bg);border:0.5px solid var(--border);border-radius:var(--r);padding:1rem;margin-bottom:1.5rem;flex-direction:row;gap:1rem;align-items:flex-start}
    .preview-card.visible{display:flex}
    .preview-thumb{width:80px;height:80px;object-fit:cover;border-radius:var(--r);flex-shrink:0}
    .preview-info{font-size:13px;color:var(--text2)}
    .preview-label{font-size:11px;letter-spacing:.5px;text-transform:uppercase;color:var(--text3);margin-bottom:4px}
    .preview-num{font-family:'Playfair Display',serif;font-size:18px;color:var(--text)}
    .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
    @media(max-width:520px){.form-grid{grid-template-columns:1fr}}
    label{font-size:11px;color:var(--text2);font-weight:500;display:block;margin-bottom:6px;letter-spacing:.4px;text-transform:uppercase}
    input[type=text],input[type=email],textarea{width:100%;padding:10px 14px;font-size:14px;border:0.5px solid var(--border2);border-radius:var(--r);background:var(--surface);color:var(--text);font-family:'Inter',sans-serif;transition:border-color .15s}
    input:focus,textarea:focus{outline:none;border-color:var(--text)}
    textarea{resize:vertical;min-height:80px}
    .form-footer{display:flex;align-items:center;justify-content:space-between;margin-top:6px;flex-wrap:wrap;gap:10px}
    .form-note{font-size:12px;color:var(--text3)}
    /* Gallery inline (voting phase) */
    .inline-gallery{max-width:720px;margin:0 auto;padding:0 2rem 3rem}
    .gallery-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px;margin-top:1.5rem}
    .card{background:var(--surface);border:0.5px solid var(--border);border-radius:var(--r);overflow:hidden;transition:transform .2s}
    .card:hover{transform:translateY(-2px)}
    .thumb{aspect-ratio:3/4;overflow:hidden;background:var(--bg);position:relative;cursor:zoom-in}
    .thumb img{width:100%;height:100%;object-fit:cover;transition:transform .4s}
    .card:hover .thumb img{transform:scale(1.03)}
    .voted-tag{position:absolute;top:8px;right:8px;background:var(--accent);color:#fff;font-size:10px;padding:3px 8px;border-radius:20px}
    .card-info{padding:10px 12px}
    .card-num{font-size:11px;color:var(--text3);letter-spacing:.5px;text-transform:uppercase;margin-bottom:6px}
    .card-footer{display:flex;align-items:center;justify-content:space-between}
    .card-votes{font-size:13px;color:var(--text2)}
    .card-votes b{color:var(--text)}
    .btn-vote{padding:5px 12px;font-size:12px;border-radius:var(--r);cursor:pointer;border:0.5px solid var(--border2);background:transparent;color:var(--text);font-family:'Inter',sans-serif;transition:all .15s}
    .btn-vote:hover{background:var(--bg)}
    .btn-vote.voted{background:var(--red-bg);border-color:#F09595;color:var(--red)}
    /* Results inline */
    .inline-results{max-width:720px;margin:0 auto;padding:0 2rem 3rem}
    .result-row{display:flex;align-items:center;gap:1rem;padding:.875rem 0;border-bottom:0.5px solid var(--border)}
    .rank{font-family:'Playfair Display',serif;font-size:20px;width:28px;flex-shrink:0;color:var(--text3)}
    .rank.top{color:var(--text)}
    .result-img{width:44px;height:44px;object-fit:cover;border-radius:var(--r);flex-shrink:0}
    .result-info{flex:1}
    .result-num{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px}
    .bar-wrap{height:3px;background:var(--border);border-radius:2px}
    .bar{height:3px;border-radius:2px;background:var(--text)}
    .result-votes{font-size:13px;font-weight:500;flex-shrink:0}
    /* Winner */
    .winner-box{background:var(--amber-bg);border:0.5px solid var(--amber-brd);border-radius:var(--r);padding:1.25rem;display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem}
    .winner-img{width:64px;height:64px;object-fit:cover;border-radius:var(--r);flex-shrink:0}
    .winner-label{font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--amber);margin-bottom:4px}
    .winner-name{font-family:'Playfair Display',serif;font-size:18px;color:#633806;margin-bottom:2px}
    .winner-votes{font-size:13px;color:var(--amber)}
    /* Lightbox */
    .lb-wrap{display:none;position:fixed;inset:0;background:rgba(0,0,0,.94);z-index:300;align-items:stretch;justify-content:center}
    .lb-wrap.open{display:flex}
    .lb-close{position:absolute;top:1rem;right:1.25rem;color:#fff;font-size:26px;cursor:pointer;opacity:.6;background:none;border:none;z-index:2;line-height:1}
    .lb-close:hover{opacity:1}
    .lb-arrow{position:absolute;top:50%;transform:translateY(-50%);color:#fff;font-size:28px;cursor:pointer;opacity:.5;background:none;border:none;padding:1rem;z-index:2}
    .lb-arrow:hover{opacity:1}
    .lb-prev{left:0}.lb-next{right:0}
    .lb-counter{position:absolute;top:1rem;left:50%;transform:translateX(-50%);color:rgba(255,255,255,.4);font-size:12px;letter-spacing:1px}
    .lb-inner{display:flex;align-items:center;justify-content:center;width:100%;padding:3rem 5rem;gap:3rem}
    @media(max-width:700px){.lb-inner{flex-direction:column;padding:3rem 1.5rem;gap:1.5rem}}
    .lb-photo{flex-shrink:0;max-width:min(420px,50vw);max-height:80vh}
    .lb-photo img{max-width:100%;max-height:80vh;object-fit:contain;border-radius:var(--r);display:block}
    @media(max-width:700px){.lb-photo{max-width:100%;max-height:45vh}}
    .lb-panel{width:280px;flex-shrink:0;display:flex;flex-direction:column;gap:1rem}
    @media(max-width:700px){.lb-panel{width:100%}}
    .lb-num{font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:4px}
    .lb-voted-badge{display:inline-flex;align-items:center;gap:5px;background:rgba(15,110,86,.25);border:0.5px solid rgba(93,202,165,.4);color:#5DCAA5;font-size:12px;padding:4px 12px;border-radius:20px;margin-bottom:8px}
    .lb-vote-form{background:rgba(255,255,255,.07);border-radius:var(--r);padding:1rem}
    .lb-vote-label{font-size:12px;color:rgba(255,255,255,.5);letter-spacing:.5px;text-transform:uppercase;margin-bottom:8px;display:block}
    .lb-email-input{width:100%;padding:9px 12px;font-size:14px;border:0.5px solid rgba(255,255,255,.2);border-radius:var(--r);background:rgba(255,255,255,.08);color:#fff;font-family:'Inter',sans-serif;margin-bottom:8px}
    .lb-email-input::placeholder{color:rgba(255,255,255,.3)}
    .lb-email-input:focus{outline:none;border-color:rgba(255,255,255,.4)}
    .lb-vote-btn{width:100%;padding:10px;background:#fff;color:#1a1a18;border:none;border-radius:var(--r);font-size:13px;font-weight:500;cursor:pointer;font-family:'Inter',sans-serif;display:flex;align-items:center;justify-content:center;gap:6px}
    .lb-vote-btn.voted{background:rgba(15,110,86,.3);color:#5DCAA5;border:0.5px solid rgba(93,202,165,.4)}
    .lb-vote-btn:disabled{opacity:.5;cursor:wait}
    .lb-err{font-size:12px;color:#f09595;margin-top:6px;display:none}
    .lb-success{font-size:13px;color:#5DCAA5;display:none;align-items:center;gap:6px;margin-top:6px}
    .lb-switch-box{background:rgba(255,200,0,.08);border:0.5px solid rgba(255,200,0,.25);border-radius:var(--r);padding:1rem;display:none;margin-top:10px}
    .lb-switch-box.show{display:block}
    .lb-switch-text{font-size:13px;color:rgba(255,255,255,.85);line-height:1.5;margin-bottom:10px}
    .lb-switch-actions{display:flex;gap:8px}
    .lb-btn-yes{flex:1;padding:8px;background:#fff;color:#1a1a18;border:none;border-radius:var(--r);font-size:13px;font-weight:500;cursor:pointer;font-family:'Inter',sans-serif}
    .lb-btn-no{flex:1;padding:8px;background:transparent;color:rgba(255,255,255,.6);border:0.5px solid rgba(255,255,255,.2);border-radius:var(--r);font-size:13px;cursor:pointer;font-family:'Inter',sans-serif}
    .lb-share{border-top:0.5px solid rgba(255,255,255,.1);padding-top:1rem;margin-top:.5rem}
    .lb-share-text{font-size:13px;color:rgba(255,255,255,.6);margin-bottom:8px;line-height:1.5}
    .lb-share-link{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.07);border:0.5px solid rgba(255,255,255,.15);border-radius:var(--r);padding:8px 12px}
    .lb-share-url{font-size:12px;color:rgba(255,255,255,.5);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-family:monospace}
    .lb-copy-btn{font-size:11px;color:#fff;background:rgba(255,255,255,.15);border:none;border-radius:4px;padding:4px 10px;cursor:pointer;font-family:'Inter',sans-serif;white-space:nowrap}
    .lb-copy-btn:hover{background:rgba(255,255,255,.25)}
    /* Prizes */
    .prizes{display:grid;grid-template-columns:repeat(3,1fr);border-top:0.5px solid var(--border);max-width:720px;margin:0 auto;background:var(--surface)}
    .prize{padding:1.25rem 2rem;border-right:0.5px solid var(--border)}
    .prize:last-child{border-right:none}
    .prize-icon{font-size:16px;margin-bottom:6px;opacity:.5}
    .prize-title{font-size:13px;font-weight:500;margin-bottom:2px}
    .prize-desc{font-size:12px;color:var(--text2)}
    footer{background:var(--surface);border-top:0.5px solid var(--border);margin-top:auto}
    .footer-inner{max-width:720px;margin:0 auto;padding:1.5rem 2rem;display:flex;align-items:center;justify-content:space-between}
    .footer-logo{font-family:'Playfair Display',serif;font-size:14px}
    .footer-links{display:flex;gap:1.5rem}
    .footer-links a{font-size:12px;color:var(--text2)}
    .footer-links a:hover{color:var(--text)}
    /* Lightbox */
    .lightbox{display:none;position:fixed;inset:0;background:rgba(0,0,0,.92);z-index:300;align-items:center;justify-content:center;padding:1rem}
    .lightbox.open{display:flex}
    /* Toast */
    .toast{position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(20px);background:var(--text);color:var(--bg);padding:12px 24px;border-radius:50px;font-size:14px;font-weight:500;opacity:0;transition:all .3s;pointer-events:none;z-index:400;white-space:nowrap}
    .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
    /* Modal */
    .modal-wrap{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:200;align-items:center;justify-content:center;padding:1rem}
    .modal-wrap.open{display:flex}
    .modal{background:var(--surface);border-radius:10px;padding:1.75rem;width:100%;max-width:380px}
    .modal h3{font-family:'Playfair Display',serif;font-size:20px;font-weight:400;margin-bottom:6px}
    .modal p{font-size:14px;color:var(--text2);margin-bottom:1rem;line-height:1.6}
    .modal-subject{background:var(--bg);border-radius:var(--r);padding:9px 14px;margin-bottom:1rem;font-size:14px;font-weight:500;border:0.5px solid var(--border)}
    .modal label{font-size:11px;color:var(--text2);font-weight:500;display:block;margin-bottom:5px;letter-spacing:.4px;text-transform:uppercase}
    .modal input{width:100%;padding:10px 14px;font-size:14px;border:0.5px solid var(--border2);border-radius:var(--r);background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;margin-bottom:6px}
    .modal input:focus{outline:none;border-color:var(--text)}
    .modal-hint{font-size:12px;color:var(--text3);margin-bottom:1rem}
    .modal-err{font-size:13px;color:var(--red);margin-bottom:10px;display:none}
    .modal-actions{display:flex;gap:8px}
    .btn-modal{flex:1;padding:10px;background:var(--text);color:var(--bg);border:none;border-radius:var(--r);font-size:13px;font-weight:500;cursor:pointer;font-family:'Inter',sans-serif}
    .btn-modal:disabled{opacity:.5;cursor:wait}
    .btn-cancel{padding:10px 18px;background:transparent;border:0.5px solid var(--border2);border-radius:var(--r);font-size:13px;cursor:pointer;font-family:'Inter',sans-serif;color:var(--text)}
  </style>
</head>
<body>
<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo"><%= settings.footer_text||'Jan Svoboda Photography' %></a>
    <div class="nav-links">
      <a href="/" class="active">Domů</a>
      <a href="/pravidla">Pravidla</a>
      <% if (typeof isAdmin !== 'undefined' && isAdmin) { %><a href="/admin">Admin</a><% } %>
    </div>
    <div class="hamburger" onclick="openMenu()"><span></span><span></span><span></span></div>
  </div>
</nav>
<div class="mobile-menu" id="mobile-menu">
  <span class="mobile-close" onclick="closeMenu()">✕</span>
  <a href="/" onclick="closeMenu()">Domů</a>
  <a href="/pravidla" onclick="closeMenu()">Pravidla</a>
  <% if(typeof isAdmin!=='undefined'&&isAdmin){%><a href="/admin" onclick="closeMenu()">Admin</a><%}%>
</div>

<% if(settings.header_photo){ %>
<img src="/uploads/<%= settings.header_photo %>" class="header-photo" alt="<%= settings.contest_title %>">
<% } %>

<% if (success) { %><div class="alert alert-success">✓ <%- decodeURIComponent((success||'').replace(/\+/g,' ')) %></div><% } %>
<% if (error) { %><div class="alert alert-error">⚠ <%- decodeURIComponent((error||'').replace(/\+/g,' ')) %></div><% } %>

<div class="hero">
  <div class="hero-eyebrow">
    Ročník 2026 &nbsp;·&nbsp;
    <% if(settings.phase==='registration'){%>Přihlášky do <%= settings.registration_end %>
    <%}else if(settings.phase==='voting'){%>Hlasování do <%= settings.voting_end %>
    <%}else{%>Soutěž ukončena<%}%>
  </div>
  <h1 class="hero-title"><%= settings.contest_title %></h1>
  <p class="hero-desc"><%= settings.home_subtitle || 'Pošlete svůj nejlepší portrétní snímek. Veřejnost hlasuje – vítěz získá profesionální focení zdarma.' %></p>

  <!-- Countdown -->
  <% const endDate = settings.phase==='registration' ? settings.registration_end : settings.voting_end; %>
  <% if (endDate && settings.phase !== 'results') { %>
  <div style="font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:var(--text3);margin-bottom:8px">
    <% if(settings.phase==='registration'){%>Zbývá do uzávěrky přihlášek<%}else{%>Zbývá do konce hlasování<%}%>
  </div>
  <div class="countdown" id="countdown" data-end="<%= endDate %>">
    <div class="cd-unit"><div class="cd-num" id="cd-d">--</div><div class="cd-label">Dní</div></div>
    <div class="cd-sep">:</div>
    <div class="cd-unit"><div class="cd-num" id="cd-h">--</div><div class="cd-label">Hodin</div></div>
    <div class="cd-sep">:</div>
    <div class="cd-unit"><div class="cd-num" id="cd-m">--</div><div class="cd-label">Minut</div></div>
    <div class="cd-sep">:</div>
    <div class="cd-unit"><div class="cd-num" id="cd-s">--</div><div class="cd-label">Sekund</div></div>
  </div>
  <% } %>

  <div class="hero-cta">
    <% if(settings.phase==='registration'){%>
      <button class="btn-dark" onclick="document.getElementById('upload-zone').scrollIntoView({behavior:'smooth'})">Přihlásit fotografii</button>
      <a href="/galerie" class="btn-ghost">Galerie →</a>
    <%}else if(settings.phase==='voting'){%>
      <span style="font-size:13px;color:var(--text2)">Hlasujte pro svého favorita níže</span>
    <%}else{%>
      <a href="/vysledky" class="btn-dark">Zobrazit výsledky</a>
    <%}%>
  </div>
</div>

<div class="stats">
  <div class="stat"><div class="stat-num"><%= formatDate(settings.registration_end) %></div><div class="stat-label">Uzávěrka přihlášek</div></div>
  <div class="stat"><div class="stat-num"><%= formatDate(settings.voting_end) %></div><div class="stat-label">Uzávěrka hlasování</div></div>
  <div class="stat"><div class="stat-num">1×</div><div class="stat-label">Fotografie na účastníka</div></div>
</div>

<% if(settings.phase==='registration'){ %>
<!-- ── Přihlašovací formulář ── -->
<div class="form-section">
  <div class="section-label"><%= settings.form_title||'Přihlásit fotografii' %></div>
  <div class="upload-zone" id="upload-zone" onclick="document.getElementById('photo').click()">
    <div class="upload-icon">↑</div>
    <p><%= settings.form_upload_text||'Klikněte nebo přetáhněte fotografii' %></p>
    <small><%= settings.form_upload_hint||'JPG, PNG, WebP – max. 15 MB · Funguje i z mobilu 📱' %></small>
    <small style="display:block;margin-top:4px;color:var(--accent)"><%= settings.form_anon_note||'Vaše údaje jsou anonymní.' %></small>
    <img id="preview-img" alt="Náhled">
  </div>
  <!-- Náhled jak bude vypadat v galerii -->
  <div class="preview-card" id="preview-card">
    <img class="preview-thumb" id="preview-thumb" src="" alt="">
    <div class="preview-info">
      <div class="preview-label">Takto vypadáte v galerii</div>
      <div class="preview-num">Zadeček č. ???</div>
      <div style="font-size:12px;color:var(--text3);margin-top:4px">Číslo bude přiděleno po schválení</div>
    </div>
  </div>
  <form action="/prihlasit" method="POST" enctype="multipart/form-data">
    <input type="file" name="photo" id="photo" accept="image/*" style="display:none" required onchange="handleFile(this)">
    <div class="form-grid">
      <div><label><%= settings.form_label_name||'Jméno a příjmení' %> *</label><input type="text" name="name" required placeholder="<%= settings.form_placeholder_name||'Jana Nováková' %>"></div>
      <div><label><%= settings.form_label_email||'E-mail' %> *</label><input type="email" name="email" required placeholder="<%= settings.form_placeholder_email||'jana@email.cz' %>"></div>
    </div>
    <div style="margin-bottom:1.25rem"><label><%= settings.form_label_note||'Krátké představení' %></label><textarea name="note" placeholder="<%= settings.form_placeholder_note||'Pár slov o sobě...' %>" maxlength="300"></textarea></div>
    <div class="form-footer">
      <span class="form-note"><%= settings.form_note||'Každý účastník může přihlásit pouze jednu fotografii.' %></span>
      <button type="submit" class="btn-dark"><%= settings.form_submit||'Odeslat →' %></button>
    </div>
  </form>
</div>

<% } else if(settings.phase==='voting'){ %>
<!-- ── Galerie s lightboxem ── -->
<div class="inline-gallery">
  <% if(votedFor){ %>
    <div style="background:var(--accent-bg);border-radius:var(--r);padding:10px 14px;font-size:13px;color:var(--accent);margin-top:1.5rem;margin-bottom:.5rem">
      ✓ Váš hlas byl odevzdán — klikněte na libovolnou fotku pro změnu nebo sdílení
    </div>
  <% }else{ %>
    <div style="font-size:13px;color:var(--text2);margin-top:1.5rem;margin-bottom:.5rem">Klikněte na fotografii pro hlasování nebo sdílení.</div>
  <% } %>
  <div class="gallery-grid">
    <% (typeof entries !== 'undefined' ? entries : []).forEach((e,idx)=>{ const isVoted=votedFor===e.id; %>
    <div class="card" onclick="openLB(<%= idx %>)">
      <div class="thumb">
        <img src="/uploads/<%= e.photo %>" alt="Zadeček č. <%= e.anon_number %>" loading="lazy">
        <% if(isVoted){%><span class="voted-tag">✓ Váš hlas</span><%}%>
      </div>
      <div class="card-info">
        <div class="card-num">Zadeček č. <%= e.anon_number %></div>
      </div>
    </div>
    <%})%>
  </div>
</div>

<% } else { %>
<!-- ── Inline výsledky ── -->
<div class="inline-results">
  <% if(typeof entries!=='undefined'&&entries.length>0&&entries[0].votes>0){ %>
  <div class="winner-box" style="margin-top:1.5rem">
    <img src="/uploads/<%= entries[0].photo %>" class="winner-img" alt="">
    <div>
      <div class="winner-label">🏆 Vítěz</div>
      <div class="winner-name">Zadeček č. <%= entries[0].anon_number %></div>
      <div class="winner-votes"><%= entries[0].votes %> hlasů · <%= settings.prize_description %></div>
    </div>
  </div>
  <% } %>
  <% if(typeof entries!=='undefined'){ const maxV=Math.max((entries[0]||{votes:1}).votes,1); entries.forEach((e,i)=>{ %>
  <div class="result-row">
    <span class="rank <%=i<3?'top':''%>"><%=i+1%></span>
    <img src="/uploads/<%= e.photo %>" class="result-img" alt="">
    <div class="result-info">
      <div class="result-num">Zadeček č. <%= e.anon_number %></div>
      <div class="bar-wrap"><div class="bar" style="width:<%=Math.round(e.votes/maxV*100)%>%"></div></div>
    </div>
    <div class="result-votes"><%= e.votes %> hl.</div>
  </div>
  <%})} %>
</div>
<% } %>

<div class="prizes">
  <div class="prize"><div class="prize-icon">🏆</div><div class="prize-title">1. místo</div><div class="prize-desc"><%= settings.prize_description %></div></div>
  <div class="prize"><div class="prize-icon">✉</div><div class="prize-title">Hlasování</div><div class="prize-desc">Každý e-mail = 1 hlas</div></div>
  <div class="prize"><div class="prize-icon">🔒</div><div class="prize-title">Anonymita</div><div class="prize-desc">Účastníci jsou anonymní</div></div>
</div>

<!-- Lightbox -->
<div class="lb-wrap" id="lb-wrap">
  <button class="lb-close" onclick="closeLB()">✕</button>
  <button class="lb-arrow lb-prev" onclick="prevLB()">‹</button>
  <button class="lb-arrow lb-next" onclick="nextLB()">›</button>
  <div class="lb-counter" id="lb-counter"></div>
  <div style="display:flex;align-items:center;justify-content:center;width:100%;padding:3rem 5rem;gap:2.5rem;flex-wrap:wrap">
    <div style="flex-shrink:0;max-width:min(420px,50vw);max-height:80vh">
      <img id="lb-img" src="" alt="" style="max-width:100%;max-height:80vh;object-fit:contain;border-radius:var(--r);display:block">
    </div>
    <div style="width:260px;flex-shrink:0;display:flex;flex-direction:column;gap:1rem">
      <div>
        <div id="lb-num" style="font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:6px"></div>
      </div>
      <div style="background:rgba(255,255,255,.07);border-radius:var(--r);padding:1rem">
        <div style="font-size:12px;color:rgba(255,255,255,.5);letter-spacing:.5px;text-transform:uppercase;margin-bottom:8px">Hlasovat</div>
        <input type="email" id="lb-email" placeholder="vas@email.cz" style="width:100%;padding:9px 12px;font-size:14px;border:0.5px solid rgba(255,255,255,.2);border-radius:var(--r);background:rgba(255,255,255,.08);color:#fff;font-family:'Inter',sans-serif;margin-bottom:8px">
        <button id="lb-vote-btn" onclick="lbVote()" style="width:100%;padding:10px;background:#fff;color:#1a1a18;border:none;border-radius:var(--r);font-size:13px;font-weight:500;cursor:pointer;font-family:'Inter',sans-serif">♡ Hlasovat</button>
        <div id="lb-err" style="font-size:12px;color:#f09595;margin-top:6px;display:none"></div>
        <div id="lb-success" style="font-size:13px;color:#5DCAA5;margin-top:6px;display:none">✓ Hlas byl zaznamenán!</div>
        <div id="lb-switch-box" style="background:rgba(255,200,0,.08);border:0.5px solid rgba(255,200,0,.3);border-radius:var(--r);padding:.875rem;margin-top:10px;display:none">
          <div id="lb-switch-text" style="font-size:12px;color:rgba(255,255,255,.85);line-height:1.5;margin-bottom:8px"></div>
          <div style="display:flex;gap:8px">
            <button onclick="lbSwitchConfirm()" style="flex:1;padding:7px;background:#fff;color:#1a1a18;border:none;border-radius:var(--r);font-size:12px;font-weight:500;cursor:pointer;font-family:'Inter',sans-serif">Ano, změnit</button>
            <button onclick="hideSwitchBox()" style="flex:1;padding:7px;background:transparent;color:rgba(255,255,255,.6);border:0.5px solid rgba(255,255,255,.2);border-radius:var(--r);font-size:12px;cursor:pointer;font-family:'Inter',sans-serif">Ne</button>
          </div>
        </div>
      </div>
      <div style="border-top:0.5px solid rgba(255,255,255,.1);padding-top:1rem">
        <div style="font-size:13px;color:rgba(255,255,255,.5);margin-bottom:8px">Líbí se ti tento zadeček? Sdílej ho!</div>
        <div style="display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.07);border:0.5px solid rgba(255,255,255,.15);border-radius:var(--r);padding:8px 12px">
          <span id="lb-share-url" style="font-size:11px;color:rgba(255,255,255,.4);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-family:monospace"></span>
          <button onclick="copyLink()" style="font-size:11px;color:#fff;background:rgba(255,255,255,.15);border:none;border-radius:4px;padding:4px 10px;cursor:pointer;font-family:'Inter',sans-serif;white-space:nowrap">Kopírovat</button>
        </div>
      </div>
    </div>
  </div>
</div>



<footer>
  <div class="footer-inner">
    <div class="footer-logo"><%= settings.footer_text||'Jan Svoboda Photography' %></div>
    <div class="footer-links">
      <a href="/pravidla">Pravidla</a>
      <a href="/galerie">Galerie</a>
      <a href="/admin/login">Admin</a>
    </div>
  </div>
</footer>

<script>
// Mobile menu
function openMenu(){document.getElementById('mobile-menu').classList.add('open');document.body.style.overflow='hidden';}
function closeMenu(){document.getElementById('mobile-menu').classList.remove('open');document.body.style.overflow='';}

// Countdown
const cdEl = document.getElementById('countdown');
if (cdEl) {
  const endStr = cdEl.dataset.end;
  const end = new Date(endStr + 'T23:59:59');
  function tick() {
    const diff = end - Date.now();
    if (diff <= 0) { cdEl.innerHTML = '<span style="font-size:14px;color:var(--text3)">Čas vypršel</span>'; return; }
    const d = Math.floor(diff/86400000);
    const h = Math.floor((diff%86400000)/3600000);
    const m = Math.floor((diff%3600000)/60000);
    const s = Math.floor((diff%60000)/1000);
    document.getElementById('cd-d').textContent = String(d).padStart(2,'0');
    document.getElementById('cd-h').textContent = String(h).padStart(2,'0');
    document.getElementById('cd-m').textContent = String(m).padStart(2,'0');
    document.getElementById('cd-s').textContent = String(s).padStart(2,'0');
  }
  tick(); setInterval(tick, 1000);
}

// Upload preview
const zone = document.getElementById('upload-zone');
if (zone) {
  zone.addEventListener('dragover', e => e.preventDefault());
  zone.addEventListener('drop', e => {
    e.preventDefault();
    const dt = new DataTransfer(); dt.items.add(e.dataTransfer.files[0]);
    document.getElementById('photo').files = dt.files;
    handleFile(document.getElementById('photo'));
  });
}
function handleFile(input) {
  if (!input.files[0]) return;
  const reader = new FileReader();
  reader.onload = e => {
    // Upload zone preview
    const img = document.getElementById('preview-img');
    img.src = e.target.result; img.style.display = 'block';
    zone.classList.add('has-file');
    // Gallery preview card
    const card = document.getElementById('preview-card');
    const thumb = document.getElementById('preview-thumb');
    thumb.src = e.target.result;
    card.classList.add('visible');
  };
  reader.readAsDataURL(input.files[0]);
}

// Lightbox
const appUrl = window.location.origin;
const lbEntries = <%- typeof entries !== 'undefined' ? JSON.stringify(entries.map(e=>({id:e.id,photo:e.photo,anon:e.anon_number,voted:votedFor===e.id}))) : '[]' %>;
let lbIdx = 0;
let pendingSwitch = null;

function openLB(idx){ lbIdx=idx; renderLB(); document.getElementById('lb-wrap').classList.add('open'); document.body.style.overflow='hidden'; }
function closeLB(){ document.getElementById('lb-wrap').classList.remove('open'); document.body.style.overflow=''; }
function prevLB(){ lbIdx=(lbIdx-1+lbEntries.length)%lbEntries.length; renderLB(); }
function nextLB(){ lbIdx=(lbIdx+1)%lbEntries.length; renderLB(); }

function renderLB(){
  if(!lbEntries.length) return;
  const e=lbEntries[lbIdx];
  document.getElementById('lb-img').src='/uploads/'+e.photo;
  const savedEmail = '<%= voterEmail||"" %>';
  if(savedEmail && !document.getElementById('lb-email').value) document.getElementById('lb-email').value = savedEmail;
  document.getElementById('lb-num').textContent='Zadeček č. '+e.anon;
  document.getElementById('lb-counter').textContent=(lbIdx+1)+' / '+lbEntries.length;
  document.getElementById('lb-share-url').textContent=appUrl+'/zadecek/'+e.id;
  document.getElementById('lb-voted-badge').style.display=e.voted?'inline-flex':'none';
  const btn=document.getElementById('lb-vote-btn');
  const errEl=document.getElementById('lb-err');
  const sucEl=document.getElementById('lb-success');
  if(errEl) errEl.style.display='none';
  if(sucEl) sucEl.style.display='none';
  hideSwitchBox();
  if(btn){btn.disabled=false;if(e.voted){btn.className='lb-vote-btn voted';btn.textContent='♥ Hlasováno';}else{btn.className='lb-vote-btn';btn.textContent='♡ Hlasovat';}}
}
function hideSwitchBox(){ const sb=document.getElementById('lb-switch-box'); if(sb){sb.classList.remove('show');pendingSwitch=null;} }

async function lbVote(){
  const email=(document.getElementById('lb-email').value||'').trim();
  const errEl=document.getElementById('lb-err'); const sucEl=document.getElementById('lb-success'); const btn=document.getElementById('lb-vote-btn');
  if(!email||!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)){errEl.textContent='Zadejte platný e-mail.';errEl.style.display='block';return;}
  btn.disabled=true;btn.textContent='Odesílám...';errEl.style.display='none';
  const e=lbEntries[lbIdx];
  try{
    const r=await fetch('/hlasovat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({entry_id:e.id,voter_email:email})});
    const data=await r.json();
    if(!data.ok){
      if(data.canSwitch){btn.disabled=false;btn.textContent='♡ Hlasovat';document.getElementById('lb-switch-text').textContent=data.error;pendingSwitch={email,newId:e.id,oldId:data.oldEntryId};document.getElementById('lb-switch-box').classList.add('show');}
      else{errEl.textContent=data.error;errEl.style.display='block';btn.disabled=false;btn.textContent='♡ Hlasovat';}
      return;
    }
    e.voted=true;btn.className='lb-vote-btn voted';btn.textContent='♥ Hlasováno';btn.disabled=false;sucEl.style.display='flex';document.getElementById('lb-voted-badge').style.display='inline-flex';
  }catch{errEl.textContent='Chyba připojení.';errEl.style.display='block';btn.disabled=false;btn.textContent='♡ Hlasovat';}
}

async function lbSwitchConfirm(){
  if(!pendingSwitch) return;
  const {email,newId,oldId}=pendingSwitch; hideSwitchBox();
  const btn=document.getElementById('lb-vote-btn'); btn.disabled=true;btn.textContent='Odesílám...';
  try{
    const r=await fetch('/hlasovat-prepsat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({entry_id:newId,voter_email:email})});
    const data=await r.json();
    if(!data.ok){document.getElementById('lb-err').textContent=data.error;document.getElementById('lb-err').style.display='block';btn.disabled=false;btn.textContent='♡ Hlasovat';return;}
    lbEntries[lbIdx].voted=true;btn.className='lb-vote-btn voted';btn.textContent='♥ Hlasováno';btn.disabled=false;
    document.getElementById('lb-success').style.display='flex';document.getElementById('lb-voted-badge').style.display='inline-flex';
    if(oldId){const old=lbEntries.find(e=>e.id===oldId);if(old)old.voted=false;}
    showToast('✓ Hlas byl změněn!');
  }catch{document.getElementById('lb-err').textContent='Chyba.';document.getElementById('lb-err').style.display='block';btn.disabled=false;btn.textContent='♡ Hlasovat';}
}

function copyLink(){navigator.clipboard.writeText(appUrl+'/zadecek/'+lbEntries[lbIdx].id).then(()=>showToast('✓ Odkaz zkopírován!')).catch(()=>{});}


document.addEventListener('keydown', e => {
  if(document.getElementById('lb-wrap').classList.contains('open')){
    if(e.key==='Escape') closeLB();
    if(e.key==='ArrowLeft') prevLB();
    if(e.key==='ArrowRight') nextLB();
  }
});


function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}


</script>
<div class="toast" id="toast"></div>
</body>
</html>
